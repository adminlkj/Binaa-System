# ============================================================================
# Binaa ERP - Environment Variables Example
# ============================================================================
# Copy this file to `.env` and fill in the real values.
# NEVER commit the real `.env` file (it is gitignored via `.env*`).
#
# To force-track this example file in git (since `.env*` ignores it):
#   git add -f .env.example
# ============================================================================

# ----------------------------------------------------------------------------
# Database (REQUIRED)
# ----------------------------------------------------------------------------
# SQLite file path (dev) or external DB URL (prod).
# Examples:
#   SQLite (relative, recommended for dev):  file:./db/custom.db
#   SQLite (absolute):                       file:/home/z/my-project/db/custom.db
#   PostgreSQL (prod):                       postgresql://user:password@localhost:5432/binaa_erp
#   MySQL (prod):                            mysql://user:password@localhost:3306/binaa_erp
DATABASE_URL="file:./db/custom.db"

# ----------------------------------------------------------------------------
# Prisma Logging (OPTIONAL)
# ----------------------------------------------------------------------------
# Set to "query" to enable verbose SQL query logging (useful in development).
# Any other value (or unset) logs only errors.
# PRISMA_LOG="query"

# ----------------------------------------------------------------------------
# Next.js Runtime (OPTIONAL - usually set by Next.js automatically)
# ----------------------------------------------------------------------------
# NODE_ENV is set automatically by Next.js (`next dev` = development,
# `next build` + `next start` = production). You should NOT set it manually
# in `.env` unless you know what you are doing.
# NODE_ENV="development"

# ----------------------------------------------------------------------------
# Public App URL (OPTIONAL)
# ----------------------------------------------------------------------------
# Used if the app needs to know its own public URL (e.g. for absolute links,
# QR codes, print URLs). Currently informational - not required by code paths.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# NextAuth (REQUIRED for authentication)
# ----------------------------------------------------------------------------
# NEXTAUTH_SECRET: secret key for JWT signing. Generate with:
#   openssl rand -base64 32
# NEXTAUTH_URL: the canonical URL of the app (used for callbacks).
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Default admin password for `bun run scripts/seed-admin.ts` (OPTIONAL).
# If unset, the default "Admin@123" is used. Change immediately after first login.
# DEFAULT_ADMIN_PASSWORD="your-strong-password-here"
