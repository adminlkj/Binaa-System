// ============ DOUBLE ENTRY ACCOUNTING ============

model Account {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  type          String
  parentId      String?
  parentCode    String?  // كود الحساب الأب - للاستعلام الهرمي السريع
  isActive      Boolean  @default(true)
  activityType  String? // CONSTRUCTION | EQUIPMENT_RENTAL | BOTH
  accountRole   String?  // الدور الوظيفي: CASH, BANK, CUSTOMER_AR, SUPPLIER_AP, RENTAL_REVENUE, PROJECT_REVENUE, FUEL_EXPENSE, MAINTENANCE_EXPENSE, PAYROLL_EXPENSE, FIXED_ASSET, VAT_INPUT, VAT_OUTPUT, etc.
  isSystem      Boolean  @default(false)
  allowPosting  Boolean  @default(true)
  level         Int      @default(0)
  description   String?
  descriptionAr String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ========================================================================
  // خصائص الاستخدام (Usage Properties) — تتحكم في ظهور الحساب في الشاشات
  // هذه الخصائص هي التي تحدد أين يظهر الحساب، وليس اسمه أو رقمه.
  // ========================================================================
  usableInExpenses    Boolean @default(false) // يستخدم في شاشة المصروفات العامة
  usableInProjects    Boolean @default(false) // يستخدم في شاشة المشاريع
  usableInRental      Boolean @default(false) // يستخدم في شاشة التأجير
  usableInPayroll     Boolean @default(false) // يستخدم في شاشة الرواتب
  usableInAdvances    Boolean @default(false) // يستخدم في شاشة السلف
  usableInMaintenance Boolean @default(false) // يستخدم في شاشة الصيانة
  usableInFuel        Boolean @default(false) // يستخدم في شاشة الوقود
  usableInPurchases   Boolean @default(false) // يستخدم في شاشة المشتريات
  usableInRevenue     Boolean @default(false) // يستخدم في شاشة الإيرادات
  showInCash          Boolean @default(false) // يظهر في شاشة الصندوق
  showInBank          Boolean @default(false) // يظهر في شاشة البنك

  // ========================================================================
  // خصائص الاختيار (Selection Properties) — تتحكم في الحقول الاختيارية
  // عندما يُختار هذا الحساب، تظهر هذه الخيارات للمستخدم (اختيارية)
  // ========================================================================
  allowsProject     Boolean @default(false) // يسمح باختيار مشروع
  allowsCostCenter  Boolean @default(false) // يسمح باختيار مركز تكلفة
  allowsEmployee    Boolean @default(false) // يسمح باختيار موظف
  allowsEquipment   Boolean @default(false) // يسمح باختيار معدة
  allowsSupplier    Boolean @default(false) // يسمح باختيار مورد
  allowsClient      Boolean @default(false) // يسمح باختيار عميل

  // ========================================================================
  // سلوك الحساب (Account Behavior) — قواعد إلزامية عند استخدام الحساب
  // هذه القواعد تُطبَّق عند إنشاء القيد: الحقول الإلزامية
  // ========================================================================
  requiresEmployee  Boolean @default(false) // يتطلب موظف (إلزامي)
  requiresProject   Boolean @default(false) // يتطلب مشروع (إلزامي)
  requiresEquipment Boolean @default(false) // يتطلب معدة (إلزامي)
  requiresContract  Boolean @default(false) // يتطلب عقد (إلزامي)
  allowsVat         Boolean @default(true)  // يسمح بالضريبة
  documentType      String? // نوع المستند: ACCRUAL | CASH | INVOICE | etc.

  parent             Account?      @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children           Account[]     @relation("AccountHierarchy")
  journalLines       JournalLine[]
  fixedAssets        FixedAsset[]  @relation("FixedAssetAccount")
  depExpenseAccounts FixedAsset[]  @relation("FixedAssetDepExpense")
  accumDepAccounts   FixedAsset[]  @relation("FixedAssetAccumDep")
  bankAccounts       BankAccount[]
  employees          Employee[]    // الموظفون المرتبطون بهذا الحساب كمصروف رواتب
  equipmentAssets    Equipment[]   @relation("EquipmentAssetAccount")

  @@index([parentId])
  @@index([type])
  @@index([isActive])
  @@index([activityType])
  @@index([accountRole])
  @@index([parentCode])
  @@index([usableInExpenses])
  @@index([usableInFuel])
  @@index([usableInMaintenance])
  @@index([usableInPayroll])
  @@index([usableInProjects])
  @@index([usableInRental])
}

model JournalEntry {
  id              String             @id @default(cuid())
  entryNo         String             @unique
  date            DateTime
  description     String?
  status          JournalEntryStatus @default(POSTED)
  sourceType      String? // SALES_INVOICE, PURCHASE_INVOICE, EXPENSE, CLIENT_PAYMENT, SUPPLIER_PAYMENT, etc.
  sourceId        String?
  isReversal      Boolean            @default(false)
  reversedEntryId String?
  isSystem        Boolean            @default(false) // قيد تلقائي من النظام
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  lines         JournalLine[]
  reversedEntry JournalEntry?  @relation("JournalEntryReversal", fields: [reversedEntryId], references: [id], onDelete: SetNull)
  reversedBy    JournalEntry[] @relation("JournalEntryReversal")

  @@index([status])
  @@index([date])
  @@index([sourceType, sourceId])
  @@index([reversedEntryId])
  @@index([isSystem])
}

model JournalLine {
  id             String    @id @default(cuid())
  journalEntryId String
  accountId      String
  costCenterId   String?
  debit          Decimal   @default(0)
  credit         Decimal   @default(0)
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([costCenterId])
}

// ============ VAT / TAX DECLARATION ============

model VATReturn {
  id                 String          @id @default(cuid())
  year               Int
  quarter            Int
  period             String
  totalSales         Decimal         @default(0)
  outputVat          Decimal         @default(0)
  totalPurchases     Decimal         @default(0)
  inputVat           Decimal         @default(0)
  netVat             Decimal         @default(0)

  // ZATCA-style category breakdown (Output / Sales side)
  standardRatedSales   Decimal       @default(0) // مبيعات خاضعة للضريبة بنسبة 15%
  zeroRatedSales       Decimal       @default(0) // مبيعات صفريه الضريبة (صادرات)
  exemptSales          Decimal       @default(0) // مبيعات معفاة من الضريبة
  standardRatedSalesVat Decimal      @default(0) // ضريبة المبيعات الخاضعة 15%

  // ZATCA-style category breakdown (Input / Purchases side)
  standardRatedPurchases Decimal     @default(0) // مشتريات خاضعة بنسبة 15%
  zeroRatedPurchases     Decimal     @default(0) // مشتريات صفريه الضريبة
  exemptPurchases        Decimal     @default(0) // مشتريات معفاة
  importsSubjectToVAT    Decimal     @default(0) // واردات خاضعة (احتساب عكسي)
  standardRatedPurchasesVat Decimal  @default(0) // ضريبة المشتريات الخاضعة 15%

  // GL cross-check (التحقق من المطابقة لدفتر اليومية)
  glOutputVat        Decimal         @default(0) // رصيد حساب ضريبة المخرجات من دفتر اليومية
  glInputVat         Decimal         @default(0) // رصيد حساب ضريبة المدخلات من دفتر اليومية
  glMatch            Boolean         @default(true) // هل تطابقت الأرقام مع دفتر اليومية؟

  // Source document ID lists (JSON arrays)
  salesInvoiceIds        String?
  purchaseInvoiceIds     String?
  expenseIds             String?
  subcontractorInvoiceIds String?
  progressClaimIds       String?

  status             VATReturnStatus @default(DRAFT)
  filedDate          DateTime?
  paymentDate        DateTime?
  paymentReference   String?
  journalEntryId     String?
  paymentJournalEntryId String?

  // Reversal / amendment tracking
  cancelledAt        DateTime?
  cancelledReason    String?
  amendedFromId      String? // الإقرار الأصلي الذي تم تعديله
  isAmendment        Boolean         @default(false)

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([status])
  @@index([year, quarter])
  @@index([period])
  @@index([amendedFromId])
}

// ============ CLIENT PAYMENTS ============

model ClientPayment {
  id                  String    @id @default(cuid())
  clientId            String
  invoiceId           String?
  amount              Decimal   @default(0)
  date                DateTime
  receivedIn          String    @default("TREASURY")
  receivingAccountId  String?
