  invoice SalesInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([invoiceId])
  @@index([date])
  @@index([clientId, date])
  @@index([paymentType])
}

// ============ SUPPLIER PAYMENTS ============

model SupplierPayment {
