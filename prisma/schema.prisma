  description    String
  amount         Decimal         @default(0)
  date           DateTime
  reference      String?
  journalEntryId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)

  @@index([equipmentId])
  @@index([category])
  @@index([date])
}

// ============ TIMESHEETS ============
// يمنع إنشاء فاتورة تأجير يدوياً - الفاتورة تنشأ من التايم شيت فقط

model Timesheet {
  id             String          @id @default(cuid())
  rentalId       String
  contractId     String
  projectId      String
  equipmentId    String
  month          Int
  year           Int
  operatingHours Decimal         @default(0)
  status         TimesheetStatus @default(DRAFT)
  approvedDate   DateTime?
  notes          String?
  // ─── Invoicing Control ───
  invoiced       Boolean         @default(false)
  invoiceId      String?         // ربط بالفاتورة بعد إصدارها
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  contract  Contract        @relation(fields: [contractId], references: [id], onDelete: Restrict)
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)
  equipment Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  rental    EquipmentRental @relation(fields: [rentalId], references: [id], onDelete: Restrict)
  invoice   SalesInvoice?

  @@index([rentalId])
  @@index([contractId])
  @@index([projectId])
  @@index([equipmentId])
  @@index([status])
  @@index([year, month])
  @@index([invoiced])
  @@unique([rentalId, year, month])
}

// ============ PETTY CASH & ADVANCES ============

model PettyCash {
  id              String   @id @default(cuid())
  branchId        String
  description     String
  amount          Decimal  @default(0)
  date            DateTime
  category        String?
  reference       String?
  transactionType String   @default("DISBURSE") // DISBURSE | FUND (P4-CRIT-011): FUND = Dr PETTY_CASH / Cr BANK; DISBURSE = Dr EXPENSE / Cr PETTY_CASH
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@index([branchId])
  @@index([date])
  @@index([category])
}

model EmployeeAdvance {
  id             String        @id @default(cuid())
  employeeId     String
  amount         Decimal       @default(0)
  date           DateTime
  settledAmount  Decimal       @default(0)
  status         AdvanceStatus @default(PENDING)
  description    String?
  journalEntryId String?

  // === تفاصيل يختارها المستخدم (المستخدم سيد النظام) ===
  // مصدر السداد عند إنشاء السلفة: بنك / نقدية / خصم على الموظف (سرقة/تلف/إهمال)
  paymentSource      String? // 'BANK' | 'CASH' | 'EMPLOYEE_DEDUCTION'
  // كود الحساب الدائن الفعلي المستخدم في القيد (يحترم اختيار المستخدم)
  paymentAccountCode String?
  // طريقة تحصيل السلفة عند التسوية: بنك / نقد / خصم من الراتب
  settlementMethod   String? // 'BANK' | 'CASH' | 'SALARY_DEDUCTION'
  // كود الحساب المدين الفعلي المستخدم في قيد التسوية
  settlementAccountCode String?
  // تاريخ التحصيل (قد يختلف عن تاريخ الإنشاء)
  settlementDate     DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([status])
  @@index([date])
}

// ============ INVENTORY ============

model InventoryItem {
