// نظام بِنَاء ERP - Complete Schema
// Binaa Construction ERP
// Updated: Restructured with proper accounting integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_PAID
  PAID
  REJECTED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
  RENTED
}

enum AdvanceStatus {
  PENDING
  PARTIALLY_SETTLED
  SETTLED
  CANCELLED
}

enum InventoryItemType {
  PRODUCT
  SERVICE
}

enum ExpenseCategory {
  // Project expenses
  RENT
  MAINTENANCE
  TRANSPORT
  DELIVERY
  CONSUMABLES
  SERVICES
  INSURANCE
  FUEL
  PERMITS
  OFFICE
  HOSPITALITY
  OTHER
  // Administrative expenses (بدون مشروع)
  SALARIES
  INTERNET
  ELECTRICITY
  WATER
  MANAGEMENT_CARS
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  INVOICED
}

enum DeliveryOrderStatus {
  PENDING
  DELIVERED
  RETURNED
  CANCELLED
}

enum VATReturnStatus {
  DRAFT
  FILED
  PAID
}

// ============ COMPANY SETTINGS ============

model CompanySetting {
  id              String   @id @default(cuid())
  nameAr          String
  nameEn          String
  logo            String?
  logoUrl         String?   // URL for the logo image
  commercialReg   String?
  taxNumber       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  bankName        String?
  bankIban        String?
  bankAccountName String?
  stamp           String?   // digital stamp image path
  defaultVatRate  Float     @default(0.15)
  currency        String    @default("SAR")
  currencySymbol    String?   // Currency symbol text (e.g. ﷼)
  currencySymbolEn  String?   // English currency text (e.g. SAR)
  currencySymbolAr  String?   // Arabic currency symbol (e.g. ﷼)
  invoiceTerms    String?
  // Unified currency - SINGLE SOURCE
  currencySymbolImage String?  // Path to uploaded currency symbol image (SVG/PNG/JPG) - PRIMARY
  headerImage         String?  // Path to invoice header image (SVG/PNG/JPG)
  footerImage         String?  // Path to invoice footer image (SVG/PNG/JPG)
  useThousandSeparatorsSystem  Boolean  @default(true)
  useThousandSeparatorsOfficial Boolean @default(false) // ZATCA: false
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============ CORE / SETTINGS ============

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects     Project[]
  warehouses   Warehouse[]
  employees    Employee[]
  pettyCashes  PettyCash[]
}

model Warehouse {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  branchId String
  isActive Boolean @default(true)

  branch         Branch       @relation(fields: [branchId], references: [id])
  inventoryItems InventoryItem[]
}

model CostCenter {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  parentId String?

  parent    CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostCenterHierarchy")
  journalLines JournalLine[]
}

model Attachment {
  id         String   @id @default(cuid())
  entityId   String
  entityType String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

// ============ CLIENTS & SUPPLIERS ============

model Client {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects      Project[]
  salesInvoices SalesInvoice[]
  rentalContracts EquipmentRental[]
  deliveryOrders EquipmentDeliveryOrder[]
}

model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  equipment       Equipment[]
}

model Subcontractor {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  specialty     String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices SubcontractorInvoice[]
}

// ============ EMPLOYEES ============

model Employee {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameAr    String?
  position  String?
  branchId  String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch    Branch           @relation(fields: [branchId], references: [id])
  advances  EmployeeAdvance[]
}

// ============ PROJECTS ============

model Project {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  nameAr        String?
  location      String?
  branchId      String
  clientId      String
  startDate     DateTime
  endDate       DateTime?
  contractValue Float         @default(0)
  status        ProjectStatus @default(PLANNING)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch         Branch           @relation(fields: [branchId], references: [id])
  client         Client           @relation(fields: [clientId], references: [id])
  contracts      Contract[]
  boqItems       BOQItem[]
  progressClaims ProgressClaim[]
  salesInvoices  SalesInvoice[]
  purchaseOrders PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  expenses       Expense[]
  laborCosts     LaborCost[]
  equipmentCosts EquipmentCost[]
  equipmentUsages EquipmentUsage[]
  subcontractorInvoices SubcontractorInvoice[]
  timesheets     Timesheet[]
}

model Contract {
  id              String         @id @default(cuid())
  projectId       String
  contractNo      String         @unique
  date            DateTime
  value           Float
  vatRate         Float          @default(0.15)
  vatAmount       Float          @default(0)
  totalValue      Float          @default(0)
  startDate       DateTime
  endDate         DateTime?
  status          ContractStatus @default(DRAFT)
  description     String?
  // Rental-specific fields
  contractType    String?        // RENTAL, PROJECT, SERVICE
  clientId        String?
  equipmentId     String?
  hourlyRate      Float?
  deliveryFees    Float          @default(0)
  deliveryFeesTaxable Boolean    @default(true)
  paymentTerms    String?
  salesOrderNo    String?        // رقم طلب البيع
  // Accounting link
  journalEntryId  String?        // Link to auto-generated journal entry
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project        Project        @relation(fields: [projectId], references: [id])
  progressClaims ProgressClaim[]
  salesInvoices  SalesInvoice[]
  timesheets     Timesheet[]
  rental         EquipmentRental?
}

// ============ BOQ (Bill of Quantities) ============

model BOQItem {
  id          String   @id @default(cuid())
  projectId   String
  code        String
  description String
  unit        String
  quantity    Float
  unitPrice   Float
  totalPrice  Float
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

// ============ PROGRESS CLAIMS (المستخلصات) ============

model ProgressClaim {
  id            String      @id @default(cuid())
  projectId     String
  contractId    String
  claimNo       String
  date          DateTime
  percentage    Float       // نسبة الإنجاز
  amount        Float       // قيمة العقد × نسبة الإنجاز
  vatRate       Float       @default(0.15)
  vatAmount     Float       @default(0)
  totalAmount   Float       @default(0)
  status        ClaimStatus @default(DRAFT)
  approvedDate  DateTime?
  notes         String?
  // Accounting link
  journalEntryId String?    // Link to auto-generated journal entry
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project  Project  @relation(fields: [projectId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])
}

// ============ SALES / CLIENT INVOICES ============

model SalesInvoice {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  projectId     String?
  contractId    String?
  clientId      String
  date          DateTime
  dueDate       DateTime
  subtotal      Float
  discountRate  Float         @default(0)
  discountAmount Float        @default(0)
  netAmount     Float         @default(0)
  vatRate       Float         @default(0.15)
  vatAmount     Float
  totalAmount   Float
  paidAmount    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  invoiceType   String        @default("SERVICE") // SERVICE, PROGRESS_CLAIM, RENTAL
  notes         String?
  paymentTerms  String?
  referenceNo   String?       // رقم المرجع
  // Rental-specific
  timesheetId   String?       @unique // Link to timesheet (for rental invoices)
  deliveryMonth String?       // الشهر من Timesheet
  includeDelivery Boolean     @default(false)
  deliveryAmount Float        @default(0)
  deliveryFeesTaxable Boolean @default(true)
  includeVat    Boolean       @default(true)
  // References pulled from contract/timesheet
  contractNo    String?
  contractType  String?
  contractPeriodStart DateTime?
  contractPeriodEnd   DateTime?
  salesOrderNo  String?
  equipmentName String?
  operatingHours Float?
  hourlyRate    Float?
  // Amount in words (cached for print)
  amountInWordsAr String?
  amountInWordsEn String?
  // Accounting link
  journalEntryId String?      // Link to auto-generated journal entry
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project   Project?  @relation(fields: [projectId], references: [id])
  contract  Contract? @relation(fields: [contractId], references: [id])
  client    Client    @relation(fields: [clientId], references: [id])
  items     SalesInvoiceItem[]
  timesheet Timesheet? @relation(fields: [timesheetId], references: [id])
}

model SalesInvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  description   String
  descriptionEn String?
  quantity      Float
  unit          String?
  unitPrice     Float
  totalPrice    Float
  itemType      String   @default("PRODUCT") // PRODUCT, SERVICE, RENTAL

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ PURCHASE WORKFLOW ============

model PurchaseRequest {
  id          String              @id @default(cuid())
  requestNo   String              @unique
  projectId   String?
  date        DateTime
  description String?
  status      PurchaseOrderStatus @default(DRAFT)
  requestedBy String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  items   PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id          String   @id @default(cuid())
  requestId   String
  description String
  quantity    Float
  unit        String?
  notes       String?

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  orderNo      String              @unique
  projectId    String?
  supplierId   String
  date         DateTime
  deliveryDate DateTime?
  subtotal     Float
  vatRate      Float               @default(0.15)
  vatAmount    Float
  totalAmount  Float
  paidAmount   Float               @default(0)
  status       PurchaseOrderStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  project  Project?  @relation(fields: [projectId], references: [id])
  supplier Supplier  @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  invoices PurchaseInvoice[]
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  description String
  quantity    Float
  unit        String?
  unitPrice   Float
  totalPrice  Float

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PurchaseInvoice {
  id               String        @id @default(cuid())
  invoiceNo        String        @unique
  purchaseOrderId  String?
  projectId        String?       // Link to project for cost tracking
  supplierId       String
  date             DateTime
  dueDate          DateTime
  subtotal         Float
  vatRate          Float         @default(0.15)
  vatAmount        Float
  totalAmount      Float
  paidAmount       Float         @default(0)
  status           InvoiceStatus @default(DRAFT)
  notes            String?
  referenceNo      String?
  expenseCategory  String?       // For accounting mapping
  // Accounting link
  journalEntryId   String?       // Link to auto-generated journal entry
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  items         PurchaseInvoiceItem[]
}

model PurchaseInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ SUBCONTRACTOR INVOICES ============

model SubcontractorInvoice {
  id              String        @id @default(cuid())
  subcontractorId String
  projectId       String?
  invoiceNo       String        @unique
  date            DateTime
  amount          Float
  vatRate         Float         @default(0.15)
  vatAmount       Float
  totalAmount     Float
  paidAmount      Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  description     String?
  // Accounting link
  journalEntryId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
}

// ============ EXPENSES ============

model Expense {
  id               String          @id @default(cuid())
  projectId        String?         // null = administrative expense
  category         ExpenseCategory
  description      String
  amount           Float
  vatAmount        Float?
  totalAmount      Float           @default(0)
  date             DateTime
  reference        String?
  payFrom          String          @default("TREASURY") // TREASURY, BANK, PETTY_CASH
  // Accounting link
  journalEntryId   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
}

// ============ LABOR COSTS ============

model LaborCost {
  id          String   @id @default(cuid())
  projectId   String
  description String
  workers     Int
  days        Float
  dailyRate   Float
  totalAmount Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

// ============ EQUIPMENT ============

model Equipment {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  nameAr         String?
  type           String?
  model          String?
  serialNumber   String?
  status         EquipmentStatus @default(AVAILABLE)
  supplierId     String?
  purchasePrice  Float           @default(0)
  hourlyRate     Float           @default(0)
  dailyRate      Float           @default(0)
  monthlyRate    Float           @default(0)
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  supplier       Supplier?             @relation(fields: [supplierId], references: [id])
  usages         EquipmentUsage[]
  maintenance    EquipmentMaintenance[]
  fuelLogs       EquipmentFuelLog[]
  rentals        EquipmentRental[]
  expenses       EquipmentExpense[]
  deliveryOrders EquipmentDeliveryOrder[]
  timesheets     Timesheet[]
}

model EquipmentUsage {
  id          String   @id @default(cuid())
  equipmentId String
  projectId   String
  date        DateTime
  hours       Float
  description String?
  cost        Float
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

model EquipmentMaintenance {
  id          String   @id @default(cuid())
  equipmentId String
  date        DateTime
  description String
  cost        Float
  nextDate    DateTime?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

model EquipmentFuelLog {
  id           String   @id @default(cuid())
  equipmentId  String
  date         DateTime
  liters       Float
  costPerLiter Float
  totalCost    Float
  projectId    String?
  createdAt    DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

model EquipmentCost {
  id          String   @id @default(cuid())
  projectId   String
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

// ============ EQUIPMENT RENTAL ============

model EquipmentRental {
  id              String         @id @default(cuid())
  contractId      String         @unique // One-to-one with Contract
  equipmentId     String
  clientId        String
  projectId       String?
  startDate       DateTime
  endDate         DateTime?
  rateType        String         @default("HOURLY") // HOURLY, DAILY, MONTHLY
  rate            Float          // سعر الساعة من العقد
  deliveryFees    Float          @default(0)
  deliveryFeesTaxable Boolean    @default(true)
  totalAmount     Float          @default(0)
  status          String         @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE
  paymentTerms    String?
  salesOrderNo    String?        // رقم طلب البيع
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contract       Contract       @relation(fields: [contractId], references: [id])
  equipment      Equipment      @relation(fields: [equipmentId], references: [id])
  client         Client         @relation(fields: [clientId], references: [id])
  deliveryOrders EquipmentDeliveryOrder[]
  timesheets     Timesheet[]
}

model EquipmentDeliveryOrder {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  rentalId      String?  // Link to rental contract
  equipmentId   String
  clientId      String?
  projectId     String?
  site          String?  // موقع المشروع
  deliveryDate  DateTime
  returnDate    DateTime?
  status        DeliveryOrderStatus @default(PENDING)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  equipment Equipment        @relation(fields: [equipmentId], references: [id])
  rental    EquipmentRental? @relation(fields: [rentalId], references: [id])
  client    Client?          @relation(fields: [clientId], references: [id])
}

model EquipmentExpense {
  id          String         @id @default(cuid())
  equipmentId String
  category    ExpenseCategory
  description String
  amount      Float
  date        DateTime
  reference   String?
  createdAt   DateTime       @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

// ============ TIMESHEETS ============

model Timesheet {
  id            String          @id @default(cuid())
  rentalId      String          // Link to rental contract
  contractId    String
  projectId     String
  equipmentId   String
  month         Int             // 1-12
  year          Int             // e.g. 2026
  operatingHours Float          @default(0) // ساعات التشغيل
  status        TimesheetStatus @default(DRAFT)
  approvedDate  DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  contract  Contract       @relation(fields: [contractId], references: [id])
  project   Project        @relation(fields: [projectId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  rental    EquipmentRental @relation(fields: [rentalId], references: [id])
  invoice   SalesInvoice?
}

// ============ PETTY CASH & ADVANCES ============

model PettyCash {
  id            String   @id @default(cuid())
  branchId      String
  description   String
  amount        Float
  date          DateTime
  category      String?
  reference     String?
  // Accounting link
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
}

model EmployeeAdvance {
  id            String        @id @default(cuid())
  employeeId    String
  amount        Float
  date          DateTime
  settledAmount Float         @default(0)
  status        AdvanceStatus @default(PENDING)
  description   String?
  // Accounting link
  journalEntryId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ INVENTORY ============

model InventoryItem {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  nameAr        String?
  itemType      InventoryItemType @default(PRODUCT)
  unit          String
  purchasePrice Float             @default(0)
  sellingPrice  Float             @default(0)
  quantity      Float             @default(0)
  minQuantity   Float             @default(0)
  warehouseId   String
  category      String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

// ============ DOUBLE ENTRY ACCOUNTING ============

model Account {
  id       String   @id @default(cuid())
  code     String   @unique
  name     String
  nameAr   String?
  type     String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentId String?
  isActive Boolean  @default(true)

  parent      Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
}

model JournalEntry {
  id          String             @id @default(cuid())
  entryNo     String             @unique
  date        DateTime
  description String?
  status      JournalEntryStatus @default(POSTED) // Auto-entries are always POSTED
  sourceType  String?            // SALES_INVOICE, PURCHASE_INVOICE, PROGRESS_CLAIM, EXPENSE, etc.
  sourceId    String?            // ID of the source document
  isReversal  Boolean            @default(false) // Whether this is a reversal entry
  reversedEntryId String?        // ID of the entry this reverses
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines JournalLine[]
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  costCenterId   String?
  debit          Float    @default(0)
  credit         Float    @default(0)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])
}

// ============ VAT / TAX DECLARATION ============

model VATReturn {
  id              String         @id @default(cuid())
  year            Int
  quarter         Int            // 1-4
  period          String         @unique // "2026-Q1"
  // Output VAT (ضريبة المخرجات)
  totalSales      Float          @default(0)
  outputVat       Float          @default(0)
  // Input VAT (ضريبة المدخلات)
  totalPurchases  Float          @default(0)
  inputVat        Float          @default(0)
  // Net
  netVat          Float          @default(0) // outputVat - inputVat
  // Snapshot details - fixed after creation
  salesInvoiceIds String?        // JSON array of sales invoice IDs included
  purchaseInvoiceIds String?     // JSON array of purchase invoice IDs included
  expenseIds      String?        // JSON array of expense IDs included
  // Status
  status          VATReturnStatus @default(DRAFT)
  filedDate       DateTime?
  paymentDate     DateTime?
  paymentReference String?
  // Accounting link
  journalEntryId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============ CLIENT PAYMENTS ============

model ClientPayment {
  id            String   @id @default(cuid())
  clientId      String
  invoiceId     String?  // Link to specific invoice
  amount        Float
  date          DateTime
  receivedIn    String   @default("TREASURY") // TREASURY, BANK
  reference     String?
  notes         String?
  // Accounting link
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ SUPPLIER PAYMENTS ============

model SupplierPayment {
  id            String   @id @default(cuid())
  supplierId    String
  invoiceId     String?  // Link to specific invoice
  amount        Float
  date          DateTime
  paidFrom      String   @default("TREASURY") // TREASURY, BANK
  reference     String?
  notes         String?
  // Accounting link
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
