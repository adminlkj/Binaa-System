// ============ RESOURCE DISTRIBUTION ============

model ResourceAllocation {
  id           String    @id @default(cuid())
  projectId    String
  resourceType String // EMPLOYEE, TEAM, EQUIPMENT
  resourceId   String // ID of Employee/WorkTeam/Equipment
  startDate    DateTime
  endDate      DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([resourceType])
}

// ============ FIXED ASSETS ============

model FixedAsset {
  id                      String   @id @default(cuid())
  assetCode               String   @unique
  name                    String
  nameAr                  String?
  category                String // EQUIPMENT, VEHICLE, OFFICE_EQUIPMENT, SOFTWARE, BUILDING, FURNITURE, OTHER
  acquisitionDate         DateTime
  acquisitionCost         Decimal  @default(0)
  residualValue           Decimal  @default(0)
  usefulLifeMonths        Int
  usefulLifeYears         Int      @default(0) // عدد السنوات (المدخل الأساسي للمستخدم)
  depreciationRate        Decimal  @default(0) // النسبة المقدرة للاهلاك سنوياً %
  depreciationMethod      String   @default("STRAIGHT_LINE")
  monthlyDepreciation     Decimal  @default(0) // الإهلاك الشهري المحسوب تلقائياً
  annualDepreciation      Decimal  @default(0) // الإهلاك السنوي المحسوب تلقائياً
  accumulatedDepreciation Decimal  @default(0)
  netBookValue            Decimal  @default(0)
  lastDepreciationDate    DateTime? // تاريخ آخر إهلاك تم تشغيله
  status                  String   @default("ACTIVE") // ACTIVE, SOLD, DISPOSED, FULLY_DEPRECIATED
  accountId               String? // حساب الأصل الثابت
  depExpenseAccountId     String? // حساب مصروف الإهلاك
  accumDepAccountId       String? // حساب مجمع الإهلاك
  journalEntryId          String? // قيد التملك (acquisition)
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  account           Account?            @relation("FixedAssetAccount", fields: [accountId], references: [id], onDelete: SetNull)
  depExpenseAccount Account?            @relation("FixedAssetDepExpense", fields: [depExpenseAccountId], references: [id], onDelete: SetNull)
  accumDepAccount   Account?            @relation("FixedAssetAccumDep", fields: [accumDepAccountId], references: [id], onDelete: SetNull)
  depreciations     AssetDepreciation[]

  @@index([status])
  @@index([category])
  @@index([accountId])
  @@index([depExpenseAccountId])
  @@index([accumDepAccountId])
}

model AssetDepreciation {
  id                 String   @id @default(cuid())
  fixedAssetId       String
  year               Int
  month              Int
  depreciationAmount Decimal  @default(0)
  beginningNBV       Decimal  @default(0) // القيمة الدفترية بداية الشهر
  endingNBV          Decimal  @default(0) // القيمة الدفترية نهاية الشهر
  journalEntryId     String?
  reversed           Boolean  @default(false) // هل تم عكس القيد
  reversedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([year, month])
  @@index([journalEntryId])
  @@unique([fixedAssetId, year, month])
}

// ============ PROVISIONS ============

model Provision {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  nameAr         String?
  type           String // END_OF_SERVICE, WARRANTY, MAINTENANCE, OTHER
  totalAmount    Decimal   @default(0)
  currentBalance Decimal   @default(0)
  startDate      DateTime
  endDate        DateTime?
  status         String    @default("ACTIVE") // ACTIVE, RELEASED, CLOSED
  journalEntryId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  movements ProvisionMovement[]

  @@index([status])
  @@index([type])
}

model ProvisionMovement {
  id             String   @id @default(cuid())
  provisionId    String
  amount         Decimal  @default(0)
  movementType   String // INCREASE, DECREASE, RELEASE
  date           DateTime
  description    String?
  journalEntryId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provision Provision @relation(fields: [provisionId], references: [id], onDelete: Cascade)

  @@index([provisionId])
  @@index([date])
}

// ============ BANK ACCOUNTS & RECONCILIATION ============

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountName   String
  accountNumber String
  iban          String?
  currency      String   @default("SAR")
  accountId     String? // Link to Chart of Accounts
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account         Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transactions    BankTransaction[]
  reconciliations BankReconciliation[]

  @@index([accountId])
  @@index([isActive])
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  date            DateTime
  description     String?
  reference       String?
  amount          Decimal  @default(0)
  transactionType String // DEPOSIT, WITHDRAWAL
  reconciled      Boolean  @default(false)
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([date])
  @@index([reconciled])
}

model BankReconciliation {
  id            String    @id @default(cuid())
  bankAccountId String
  year          Int
  month         Int
  bookBalance   Decimal   @default(0)
  bankBalance   Decimal   @default(0)
  difference    Decimal   @default(0)
  status        String    @default("DRAFT") // DRAFT, COMPLETED
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([year, month])
  @@unique([bankAccountId, year, month])
}

// ============ FINANCIAL MAPPING ENGINE ============
// محرك الربط المحاسبي - يحدد الأدوار المدينة والدائنة لكل نوع عملية
// عندما يغير المحاسب الحساب المرتبط بدور ما، تتغير جميع القيود تلقائياً

model FinancialMapping {
  id              String   @id @default(cuid())
  operationType   String   @unique // RENTAL_INVOICE, PAYROLL, SUPPLIER_PAYMENT, CLIENT_PAYMENT, etc.
  labelAr         String   // التسمية العربية لنوع العملية
  labelEn         String   // التسمية الإنجليزية
  description     String?  // وصف العملية
  debitRoles      String   // JSON array of AccountRole keys for debit side
  creditRoles     String   // JSON array of AccountRole keys for credit side
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([operationType])
  @@index([isActive])
}

// ============ ACCOUNTING HEALTH CHECK ============
// فحص السلامة المحاسبي - يفحص صحة الربط المحاسبي يومياً

model AccountingHealthCheck {
  id            String   @id @default(cuid())
  checkDate     DateTime @default(now())
  overallScore  Int      @default(0) // 0-100 percentage
  totalChecks   Int      @default(0)
  passedChecks  Int      @default(0)
  warnings      Int      @default(0)
  errors        Int      @default(0)
  details       String   // JSON array of check results
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([checkDate])
  @@index([overallScore])
}

// ============ PERIOD CLOSING ============

model PeriodClosing {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  type           String   @default("MONTHLY") // MONTHLY, YEARLY
  status         String   @default("CLOSED") // CLOSED, OPEN, REOPENED
  closingEntryId String? // Journal entry for closing
  closedAt       DateTime @default(now())
  closedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([year, month, type])
  @@index([status])
  @@index([year, month])
}

// ============================================================================
// Phase 1-2 — IFRS 15 + Project Controls + Subcontractor Lifecycle Models
// ============================================================================

// ── WBS (Work Breakdown Structure) ──────────────────────────────────────
model WBSElement {
  id          String   @id @default(cuid())
  code        String
  projectId   String
  parentId    String?
  level       Int      @default(1)
  name        String
  elementType String   @default("WORK_PACKAGE") // PROJECT, PHASE, DELIVERABLE, WORK_PACKAGE
  weight      Decimal  @default(0) // weight in % for progress calc
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, ON_HOLD
  startDate   DateTime?
  endDate     DateTime?
  progress    Decimal  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      WBSElement?  @relation("WBSHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    WBSElement[] @relation("WBSHierarchy")
  costEntries CostEntry[]
  costCodeBudgets CostCodeBudget[]
  projectLedger ProjectLedger[]
  activities  Activity[]
  boqItems    BOQItem[]
  measurements Measurement[]
  claimItems  ClaimItem[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([parentId])
}

// ── Cost Codes ──────────────────────────────────────────────────────────
model CostCode {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  category  String   // LABOR, MATERIAL, EQUIPMENT, SUBCONTRACTOR, OVERHEAD, INDIRECT
  parentId  String?
  level     Int      @default(1)
  unit      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent        CostCode?         @relation("CostCodeHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children      CostCode[]        @relation("CostCodeHierarchy")
  costEntries   CostEntry[]
  costCodeBudgets CostCodeBudget[]
  projectLedger ProjectLedger[]

  @@index([category])
  @@index([parentId])
}

// ── Activities (Schedule Activities) ─────────────────────────────────────
model Activity {
  id               String   @id @default(cuid())
  code             String
  projectId        String
  wbsElementId     String?
  name             String
  activityType     String   @default("CONSTRUCTION") // CONSTRUCTION, ENGINEERING, PROCUREMENT, COMMISSIONING
  status           String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, ON_HOLD
  startDate        DateTime?
  endDate          DateTime?
  plannedQuantity  Decimal  @default(0)
  actualQuantity   Decimal  @default(0)
  progress         Decimal  @default(0)
  weight           Decimal  @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElement WBSElement?  @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  costEntries CostEntry[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([wbsElementId])
}

// ── Cost Entry (Unified Cost Collection) ────────────────────────────────
model CostEntry {
  id              String   @id @default(cuid())
  projectId       String
  wbsElementId    String?
  costCodeId      String?
  activityId      String?
  costCenterId    String?
  costType        String   // MATERIALS, LABOR, EQUIPMENT, SUBCONTRACTOR, OVERHEAD, INDIRECT
  sourceType      String   // GRN, EXPENSE, SUBCONTRACTOR_INVOICE, LABOR_COST, EQUIPMENT_COST, SALARY, MANUAL, JOURNAL
  sourceId        String?
  sourceDocument  String?
  description     String
  quantity        Decimal  @default(0)
  unit            String?
  unitCost        Decimal  @default(0)
  amount          Decimal
  date            DateTime
  periodYear      Int
  periodMonth     Int
  isCommitted     Boolean  @default(false)
  journalEntryId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElement WBSElement?  @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  costCode   CostCode?    @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  activity   Activity?    @relation(fields: [activityId], references: [id], onDelete: SetNull)
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([costType])
  @@index([sourceType, sourceId])
  @@index([wbsElementId, costCodeId])
  @@index([activityId])
  @@index([costCenterId])
}

// ── Cost Code Budget (WBS × CostCode matrix) ────────────────────────────
model CostCodeBudget {
  id             String   @id @default(cuid())
  projectId      String
  wbsElementId   String
  costCodeId     String
  budgetAmount   Decimal  @default(0)
  committedAmount Decimal @default(0)
  actualAmount   Decimal  @default(0)
  earnedAmount   Decimal  @default(0)
  forecastAmount Decimal  @default(0)
  variance       Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  wbsElement WBSElement @relation(fields: [wbsElementId], references: [id], onDelete: Cascade)
  costCode   CostCode   @relation(fields: [costCodeId], references: [id], onDelete: Cascade)

  @@unique([wbsElementId, costCodeId])
  @@index([projectId])
  @@index([costCodeId])
}

// ── Project Ledger (Single Source of Truth) ─────────────────────────────
model ProjectLedger {
  id             String   @id @default(cuid())
  projectId      String
  wbsElementId   String?
  costCodeId     String?
  activityId     String?
  ledgerType     String   // COST, REVENUE, WIP, CONTRACT_ASSET, CONTRACT_LIABILITY, RETENTION, ADVANCE, COMMITMENT, CASH
  entryDate      DateTime
  description    String?
  debit          Decimal  @default(0)
  credit         Decimal  @default(0)
  runningBalance Decimal  @default(0)
  reference      String?
  journalEntryId String?
  sourceType     String?
  sourceId       String?
  createdAt      DateTime @default(now())

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElement WBSElement?  @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  costCode   CostCode?    @relation(fields: [costCodeId], references: [id], onDelete: SetNull)

  @@index([projectId, entryDate])
  @@index([ledgerType])
  @@index([wbsElementId])
  @@index([costCodeId])
}

// ── Commitment Accounting (PO + Subcontract open commitments) ────────────
model Commitment {
  id                  String    @id @default(cuid())
  commitmentNo        String    @unique
  projectId           String
  commitmentType      String    // PURCHASE_ORDER, SUBCONTRACT, SERVICE_CONTRACT
  vendorId            String?
  description         String?
  committedAmount     Decimal
  invoicedAmount      Decimal   @default(0)
  receivedAmount      Decimal   @default(0)
  remainingCommitment Decimal   @default(0)
  commitmentDate      DateTime
  status              String    @default("OPEN") // OPEN, PARTIALLY_INVOICED, FULLY_INVOICED, CANCELLED
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   CommitmentLine[]

  @@index([projectId])
  @@index([status])
}

model CommitmentLine {
  id            String   @id @default(cuid())
  commitmentId  String
  wbsElementId  String?
  costCodeId    String?
  description   String?
  quantity      Decimal  @default(0)
  unitPrice     Decimal  @default(0)
  lineAmount    Decimal  @default(0)
  createdAt     DateTime @default(now())

  commitment Commitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)

  @@index([commitmentId])
}

// ── Subcontractor Lifecycle (Advance / Retention / Payment) ─────────────
model SubcontractorAdvance {
  id                String   @id @default(cuid())
  advanceNo         String   @unique
  subcontractorId   String
  projectId         String
  contractId        String?
  date              DateTime
  amount            Decimal
  deductionPercent Decimal  @default(0)
  recoveryMethod    String   @default("PER_CERTIFICATE") // PER_CERTIFICATE, FIXED, LUMP_SUM
  status            String   @default("PENDING") // PENDING, PARTIALLY_SETTLED, SETTLED, CANCELLED
  recoveredAmount   Decimal  @default(0)
  notes             String?
  journalEntryId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([subcontractorId])
  @@index([projectId])
}

model SubcontractorRetention {
  id                  String   @id @default(cuid())
  retentionNo         String   @unique
  subcontractorId     String
  projectId           String
  subcontractorInvoiceId String?
  date                DateTime
  withheldAmount      Decimal
  releasedAmount      Decimal  @default(0)
  status              String   @default("WITHHELD") // WITHHELD, PARTIALLY_RELEASED, FULLY_RELEASED
  releaseDate         DateTime?
  notes               String?
  journalEntryId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([subcontractorId])
  @@index([projectId])
}

model SubcontractorPayment {
  id                    String   @id @default(cuid())
  paymentNo             String   @unique
  subcontractorId       String
  subcontractorInvoiceId String?
  paymentDate           DateTime
  paymentMethod         String   @default("BANK_TRANSFER") // CASH, BANK_TRANSFER, CHEQUE
  bankAccountId         String?
  chequeNo              String?
  amount                Decimal
  status                String   @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED
  notes                 String?
  journalEntryId        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subcontractor       Subcontractor       @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  subcontractorInvoice SubcontractorInvoice? @relation(fields: [subcontractorInvoiceId], references: [id], onDelete: SetNull)

  @@index([subcontractorId])
  @@index([subcontractorInvoiceId])
}

// ── Claim Items + Measurements + Certifications (IFRS 15 chain) ─────────
model ClaimItem {
  id                String   @id @default(cuid())
  claimId           String
  boqItemId         String?
  wbsElementId      String?
  description       String
  unit              String?
  previousQuantity  Decimal  @default(0)
  currentQuantity   Decimal  @default(0)
  cumulativeQuantity Decimal @default(0)
  unitPrice         Decimal  @default(0)
  totalAmount       Decimal  @default(0)
  retentionPercent  Decimal  @default(0)
  retentionAmount   Decimal  @default(0)
  advanceDeduction  Decimal  @default(0)
  penaltyAmount     Decimal  @default(0)
  otherDeductions   Decimal  @default(0)
  netAmount         Decimal  @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  claim       ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  boqItem     BOQItem?      @relation(fields: [boqItemId], references: [id], onDelete: SetNull)
  wbsElement  WBSElement?   @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  measurement Measurement?

  @@index([claimId])
  @@index([boqItemId])
  @@index([wbsElementId])
}

model Measurement {
  id                 String   @id @default(cuid())
  code               String   @unique
  projectId          String
  wbsElementId       String?
  boqItemId          String?
  claimItemId        String?  @unique
  description        String
  measurementDate    DateTime
  measuredBy         String?
  surveyorName       String?
  contractQuantity   Decimal  @default(0)
  previousQuantity   Decimal  @default(0)
  currentQuantity    Decimal  @default(0)
  cumulativeQuantity Decimal  @default(0)
  rejectedQuantity   Decimal  @default(0)
  unit               String?
  unitRate           Decimal  @default(0)
  previousAmount     Decimal  @default(0)
  currentAmount      Decimal  @default(0)
  cumulativeAmount   Decimal  @default(0)
  status             String   @default("DRAFT") // DRAFT, SUBMITTED, CERTIFIED, REJECTED
  certifiedQuantity  Decimal  @default(0)
  certifiedAmount    Decimal  @default(0)
  certifiedDate      DateTime?
  certifiedBy        String?
  rejectionReason    String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsElement WBSElement? @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  boqItem    BOQItem?    @relation(fields: [boqItemId], references: [id], onDelete: SetNull)
  claimItem  ClaimItem?  @relation(fields: [claimItemId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([wbsElementId])
  @@index([boqItemId])
}

model ClaimCertification {
  id                  String   @id @default(cuid())
  claimId             String   @unique
  certifiedBy         String?
  certificationDate   DateTime
  claimedAmount       Decimal  @default(0)
  certifiedAmount     Decimal  @default(0)
  deductedAmount      Decimal  @default(0)
  retentionAmount     Decimal  @default(0)
  advanceDeduction    Decimal  @default(0)
  penaltyAmount       Decimal  @default(0)
  otherDeductions     Decimal  @default(0)
  netPayable          Decimal  @default(0)
  status              String   @default("CERTIFIED") // PENDING, CERTIFIED, REJECTED
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  claim ProgressClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
}

// ── WIP Entries (IFRS 15 Work in Progress) ──────────────────────────────
model WIPEntry {
  id             String   @id @default(cuid())
  projectId      String
  wbsElementId   String?
  entryDate      DateTime
  costsIncurred  Decimal  @default(0)
  progressPercent Decimal @default(0)
  revenueRecognized Decimal @default(0)
  grossProfit    Decimal  @default(0)
  journalEntryId String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, entryDate])
}

model WIPAdjustment {
  id             String   @id @default(cuid())
  projectId      String
  adjustmentDate DateTime
  adjustmentType String   // LOSS_PROVISION, REVERSAL, RESTATEMENT
  amount         Decimal
  reason         String?
  journalEntryId String?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Project Budget & Forecast (EVM) ─────────────────────────────────────
model ProjectBudget {
  id            String   @id @default(cuid())
  projectId     String
  budgetType    String   @default("ORIGINAL") // ORIGINAL, REVISED, SUPPLEMENTARY
  totalAmount   Decimal  @default(0)
  approvedDate  DateTime
  approvedBy    String?
  notes         String?
  createdAt     DateTime @default(now())

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   ProjectBudgetLine[]

  @@index([projectId])
}

model ProjectBudgetLine {
  id            String   @id @default(cuid())
  budgetId      String
  wbsElementId  String?
  costCodeId    String?
  description   String?
  amount        Decimal  @default(0)
  createdAt     DateTime @default(now())

  budget ProjectBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model ProjectForecast {
  id                  String   @id @default(cuid())
  projectId           String
  forecastDate        DateTime
  contractValue       Decimal  @default(0)
  estimatedTotalCost  Decimal  @default(0)
  costsIncurredToDate Decimal  @default(0)
  costsToComplete     Decimal  @default(0)
  expectedProfit      Decimal  @default(0)
  expectedLoss        Decimal  @default(0)
  status              String   @default("ACTIVE") // ACTIVE, ARCHIVED
  // EVM metrics
  pv                  Decimal  @default(0)
  ev                  Decimal  @default(0)
  ac                  Decimal  @default(0)
  bac                 Decimal  @default(0)
  etc                 Decimal  @default(0)
  eac                 Decimal  @default(0)
  vac                 Decimal  @default(0)
  cpi                 Decimal  @default(0)
  spi                 Decimal  @default(0)
  cv                  Decimal  @default(0)
  sv                  Decimal  @default(0)
  percentComplete     Decimal  @default(0)
  percentSpent        Decimal  @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

model LossProvision {
  id            String   @id @default(cuid())
  projectId     String
  provisionDate DateTime
  amount        Decimal
  reason        String?
  status        String   @default("ACTIVE") // ACTIVE, REVERSED
  journalEntryId String?
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Customer Advance & Recovery ─────────────────────────────────────────
model CustomerAdvance {
  id               String   @id @default(cuid())
  clientId         String
  projectId        String?
  advanceNo        String   @unique
  date             DateTime
  amount           Decimal
  recoveredAmount  Decimal  @default(0)
  status           String   @default("ACTIVE") // ACTIVE, FULLY_RECOVERED, CANCELLED
  notes            String?
  journalEntryId   String?
  createdAt        DateTime @default(now())

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

model AdvanceRecovery {
  id               String   @id @default(cuid())
  customerAdvanceId String
  invoiceId        String?
  date             DateTime
  amount           Decimal
  notes            String?
  journalEntryId   String?
  createdAt        DateTime @default(now())

  @@index([customerAdvanceId])
}

// ── Stock Movements (Inventory) ─────────────────────────────────────────
model StockMovement {
  id            String   @id @default(cuid())
  inventoryItemId String
  movementType  String   // RECEIPT, ISSUE, TRANSFER, ADJUSTMENT, RETURN
  quantity      Decimal
  unitCost      Decimal  @default(0)
  totalAmount   Decimal  @default(0)
  movementDate  DateTime
  reference     String?
  journalEntryId String?
  createdAt     DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([movementDate])
}
