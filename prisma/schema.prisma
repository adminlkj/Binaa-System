// نظام بِنَاء ERP - Complete Schema
// Binaa Construction ERP
// Version 2.0 - Restructured per comprehensive audit

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseRequestStatus {
  NEW
  APPROVED
  CONVERTED_TO_PO
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_PAID
  PAID
  REJECTED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
  RENTED
}

enum EquipmentOwnershipType {
  COMPANY_OWNED    // مملوكة للشركة
  LEASED_ASSET    // مستأجرة من طرف آخر
  CUSTOMER_OWNED  // معدات عميل
}

enum AdvanceStatus {
  PENDING
  PARTIALLY_SETTLED
  SETTLED
  CANCELLED
}

enum InventoryItemType {
  PRODUCT
  SERVICE
}

enum ProjectType {
  CONSTRUCTION
  EQUIPMENT_RENTAL
}

enum ExpenseType {
  PROJECT
  INTERNAL
}

enum ExpenseCategory {
  // === Legacy categories (kept for backward compatibility with historical records) ===
  // These are redirected to specialized screens for NEW entries:
  //   FUEL, MAINTENANCE, DRIVERS, TRANSPORT, DELIVERY, CONSUMABLES, SERVICES,
  //   SALARIES, PERMITS → specialized screens
  // MANAGEMENT_CARS → kept as legacy general (use ADMIN_VEHICLES_* for new entries)
  RENT
  MAINTENANCE
  TRANSPORT
  DELIVERY
  CONSUMABLES
  SERVICES
  INSURANCE
  FUEL
  PERMITS
  OFFICE
  HOSPITALITY
  OTHER
  SALARIES
  INTERNET
  ELECTRICITY
  WATER
  MANAGEMENT_CARS
  DRIVERS

  // === NEW: General & Administrative expense categories ===
  // المرافق والخدمات (Utilities & Services)
  SEWAGE
  TELECOM
  POSTAL
  CLOUD_HOSTING

  // المركبات العامة للشركة (Administrative Vehicles — NOT project/rental equipment)
  ADMIN_VEHICLES_FUEL
  ADMIN_VEHICLES_MAINT
  VEHICLE_WASH
  TIRES
  OILS_FILTERS
  ROAD_PARKING_FEES

  // المباني والمكاتب (Buildings & Offices)
  BUILDING_MAINT
  CLEANING
  SECURITY
  FURNITURE
  OFFICE_EQUIPMENT
  STATIONERY

  // المصروفات الحكومية (Government Fees)
  GOV_FEES
  FINES
  VIOLATIONS
  MUNICIPAL_FEES
  CHAMBER_FEES
  HR_MINISTRY_FEES
  GOSI_FEES
  PASSPORT_FEES
  RESIDENCY_FEES
  VISA_FEES
  LICENSE_FEES

  // التأمين (Insurance — non-payroll)
  MEDICAL_INSURANCE
  VEHICLE_INSURANCE
  EQUIPMENT_INSURANCE
  FIRE_INSURANCE
  PROPERTY_INSURANCE

  // الاشتراكات والخدمات (Subscriptions & Services)
  SOFTWARE_SUBSCRIPTIONS
  SYSTEM_SUBSCRIPTIONS
  WEBSITE_SUBSCRIPTIONS
  NEWSPAPERS
  PROFESSIONAL_MEMBERSHIPS

  // المصروفات المالية (Financial Expenses)
  BANK_FEES
  BANK_COMMISSIONS
  TRANSFER_DIFFERENCES
  POS_FEES
  PAYMENT_GATEWAY_FEES

  // الموارد البشرية العامة (General HR — NOT salaries/payroll/advances)
  EMPLOYEE_TRAINING
  RECRUITMENT
  JOB_ADVERTISEMENTS
  NON_PAYROLL_BONUSES
  ADMIN_ALLOWANCES

  // السفر والانتداب (Travel & Deputation)
  TRAVEL_TICKETS
  HOTELS
  DEPUTATIONS
  TRAVEL_ALLOWANCE
  EXTERNAL_HOSPITALITY

  // مصروفات متنوعة (Miscellaneous)
  DONATIONS
  MINOR_LOSSES
  CASH_DIFFERENCES
  MATERIAL_DAMAGE
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  INVOICED
}

enum DeliveryOrderStatus {
  PENDING
  DELIVERED
  RETURNED
  CANCELLED
}

enum AccountActivityType {
  CONSTRUCTION
  EQUIPMENT_RENTAL
  BOTH
}

// Activity type for business flow - every record knows which hub it belongs to
enum ActivityType {
  EXECUTION // مشاريع تنفيذية
  RENTAL    // تأجير معدات
  GENERAL   // مشترك / عام
}

enum VATReturnStatus {
  DRAFT
  FILED
  PAID
  CANCELLED
  AMENDED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
}

enum SalaryStatus {
  DRAFT
  APPROVED
  PAID
}

enum SalaryType {
  MONTHLY
  HOURLY
}

enum PayrollRunStatus {
  DRAFT
  REVIEW
  APPROVED
  PARTIALLY_PAID
  PAID
}

enum GoodsReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

enum ChangeOrderStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum WarrantyType {
  PERFORMANCE     // ضمان أداء
  ADVANCEMENT     // ضمان دفعة مقدمة
  RETENTION       // ضمان استقطاع
  MAINTENANCE     // ضمان صيانة
}

// ============ COMPANY SETTINGS ============
// المصدر المركزي الوحيد لبيانات الشركة - يمنع تكرارها في أي مكان آخر

model CompanySetting {
  id                            String   @id @default(cuid())
  nameAr                        String
  nameEn                        String
  logo                          String?
  logoUrl                       String?
  commercialReg                 String?
  taxNumber                     String?
  address                       String?
  phone                         String?
  email                         String?
  website                       String?
  bankName                      String?
  bankIban                      String?
  bankAccountName               String?
  stamp                         String?
  defaultVatRate                Decimal  @default(0.15)
  currency                      String   @default("SAR")
  currencySymbol                String?
  currencySymbolEn              String?
  currencySymbolAr              String?
  invoiceTerms                  String?
  currencySymbolImage           String?
  headerImage                   String?
  footerImage                   String?
  headerHeight                  Int      @default(30)
  footerHeight                  Int      @default(22)
  useThousandSeparatorsSystem   Boolean  @default(true)
  useThousandSeparatorsOfficial Boolean  @default(false)
  decimalPlaces                 Int      @default(2)
  // Invoice template customization
  invoiceTemplate               String   @default("classic") // classic, modern, minimal, corporate, royal, ocean
  invoicePrimaryColor           String   @default("#0f766e") // Tailwind emerald-700
  invoiceAccentColor            String   @default("#34d399") // Tailwind emerald-400
  invoiceFontFamily             String   @default("default") // default, tajawal, cairo, amiri
  invoiceShowBankDetails        Boolean  @default(true)
  invoiceShowSignature          Boolean  @default(true)
  invoiceShowStamp              Boolean  @default(false)
  // Stamp placement & size — user has full control over where and how big
  // the company stamp appears on the printed invoice.
  // Positions: top-right, top-left, bottom-right, bottom-left, before-signatures, after-totals, center
  stampPosition                 String   @default("after-signatures")
  stampWidth                    Int      @default(140) // px
  stampHeight                   Int      @default(140) // px
  stampOffsetX                  Int      @default(0)    // px (+/- offset on X axis)
  stampOffsetY                  Int      @default(0)    // px (+/- offset on Y axis)
  stampOpacity                  Decimal  @default(0.9)  // 0.0 - 1.0
  stampRotation                 Int      @default(0)    // degrees -15..15
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

// ============ CORE / SETTINGS ============

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  warehouses  Warehouse[]
  employees   Employee[]
  pettyCashes PettyCash[]
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  branchId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  inventoryItems InventoryItem[]

  @@index([branchId])
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameAr    String?
  symbol    String
  symbolImage String?   // صورة رمز العملة
  rate      Decimal  @default(1)
  decimalPlaces Int    @default(2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CostCenter {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  parentId  String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent       CostCenter?   @relation("CostCenterHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children     CostCenter[]  @relation("CostCenterHierarchy")
  journalLines JournalLine[]
  expenses     Expense[]
  costEntries  CostEntry[]
  projects     Project[]

  @@index([parentId])
  @@index([isActive])
}

model Attachment {
  id         String   @id @default(cuid())
  entityId   String
  entityType String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity, entityId])
  @@index([userId])
}

// ============ FISCAL YEAR & PERIODS ============

model FiscalYear {
  id                     String   @id @default(cuid())
  name                   String   @unique // e.g. "2025"
  startDate              DateTime
  endDate                DateTime
  status                 String   @default("OPEN") // OPEN, CLOSING, CLOSED
  // Closing support
  closingJournalEntryId  String?  // قيد إقفال السنة
  openingJournalEntryId  String?  // قيد افتتاح السنة الجديدة (ترحيل الأرصدة)
  retainedEarningsAccountCode String? // حساب الأرباح المرحلة المستخدم في الإقفال
  closedBy               String?
  closedAt               DateTime?
  closingNotes           String?
  // Summary totals (cached at closing time)
  totalRevenue           Decimal  @default(0)
  totalExpenses          Decimal  @default(0)
  netProfit              Decimal  @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  periods FiscalPeriod[]

  @@index([status])
  @@index([startDate, endDate])
}

model FiscalPeriod {
  id         String   @id @default(cuid())
  fiscalYearId String
  periodNo   Int      // 1-12
  startDate  DateTime
  endDate    DateTime
  status     String   @default("OPEN") // OPEN, CLOSED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@unique([fiscalYearId, periodNo])
  @@index([fiscalYearId])
  @@index([status])
  @@index([startDate, endDate])
}

// ============ CLIENTS & SUPPLIERS ============

model Client {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  nameEn        String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  // P6-CRIT-009 FIX: soft-delete (mirror of Supplier.deletedAt added in Phase 5).
  // DELETE now sets deletedAt=now + isActive=false instead of crashing on FK constraints.
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects        Project[]
  contracts       Contract[]
  salesInvoices   SalesInvoice[]
  rentalContracts EquipmentRental[]
  deliveryOrders  EquipmentDeliveryOrder[]
  clientPayments  ClientPayment[]
  customerAdvances CustomerAdvance[]

  @@index([isActive])
  @@index([deletedAt])
}

model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  nameEn        String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  commercialReg String?
  paymentTerms  String?
  creditLimit   Decimal  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  purchaseOrders       PurchaseOrder[]
  purchaseInvoices     PurchaseInvoice[]
  equipment            Equipment[]
  goodsReceipts        GoodsReceipt[]
  supplierPayments     SupplierPayment[]
  equipmentMaintenance EquipmentMaintenance[]

  @@index([isActive])
  @@index([deletedAt])
}

model Subcontractor {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  nameEn        String?
  specialty     String?
  idOrRegNumber String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices  SubcontractorInvoice[]
  contracts SubcontractorContract[]
  // ── Phase 2 relations ──
  advances   SubcontractorAdvance[]
  retentions SubcontractorRetention[]
  payments   SubcontractorPayment[]

  @@index([isActive])
}

// ============ EMPLOYEES ============
// المصدر المركزي للعمالة - جميع الوحدات تعتمد عليه

model Employee {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String
  nameAr          String?
  nationality     String?
  profession      String?
  residenceNumber String?
  residenceExpiry DateTime?
  hireDate        DateTime?
  basicSalary     Decimal        @default(0)
  salaryType      SalaryType     @default(MONTHLY) // شهري أو بالساعة
  referenceMonthlyHours Decimal  @default(240) // عدد ساعات المرجعية الشهرية للموظفين بالساعة
  housingAllowance Decimal       @default(0)
  transportAllowance Decimal     @default(0)
  otherAllowances Decimal        @default(0)
  hourlyRate      Decimal        @default(0) // معدل الساعة للموظفين بالساعة
  hasGosi         Boolean        @default(false) // خاضع للتأمينات الاجتماعية
  gosiPercentage  Decimal        @default(0) // نسبة استقطاع التأمينات (مثال: 9.75)
  status          EmployeeStatus @default(ACTIVE)
  branchId        String
  phone           String?
  email           String?
  isActive        Boolean        @default(true)
  expenseAccountId String?       // حساب مصروف الراتب - يحدد الحساب المحاسبي لرواتب هذا الموظف
  deletedAt       DateTime?      // soft-delete (P4-CRIT-012)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  branch          Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  expenseAccount  Account?             @relation(fields: [expenseAccountId], references: [id], onDelete: SetNull)
  advances        EmployeeAdvance[]
  contracts       EmployeeContract[]
  attendance      Attendance[]
  salaries        Salary[]
  teamMemberships TeamMember[]
  operatorLogs    EquipmentOperation[]
  laborCosts      LaborCost[]
  payrollLines    PayrollRunLine[]
  salaryPayments  SalaryPayment[]

  @@index([branchId])
  @@index([expenseAccountId])
  @@index([status])
  @@index([isActive])
}

model EmployeeContract {
  id                 String    @id @default(cuid())
  employeeId         String
  startDate          DateTime
  endDate            DateTime?
  basicSalary        Decimal   @default(0)
  housingAllowance   Decimal   @default(0)
  transportAllowance Decimal   @default(0)
  otherAllowances    Decimal   @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
}

model Attendance {
  id            String    @id @default(cuid())
  employeeId    String
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  workHours     Decimal   @default(0)
  overtimeHours Decimal   @default(0)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([date])
  @@index([employeeId, date])
}

model Salary {
  id                 String       @id @default(cuid())
  employeeId         String
  projectId          String? // ربط بالمشروع لتحميل التكلفة
  activityType       String       @default("GENERAL") // EXECUTION, RENTAL, GENERAL
  month              Int // 1-12
  year               Int
  basicSalary        Decimal      @default(0)
  housingAllowance   Decimal      @default(0)
  transportAllowance Decimal      @default(0)
  otherAllowances    Decimal      @default(0)
  overtimeAmount     Decimal      @default(0)
  deductions         Decimal      @default(0)
  netSalary          Decimal      @default(0)
  status             SalaryStatus @default(DRAFT)
  journalEntryId     String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([projectId])
  @@index([status])
  @@index([year, month])
}

model WorkTeam {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameAr    String?
  specialty String?
  projectId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  members TeamMember[]
  payrollLines PayrollRunLine[]

  @@index([projectId])
  @@index([isActive])
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  employeeId String
  role       String?
  isLeader   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team     WorkTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([teamId])
  @@index([employeeId])
}

// ============ PAYROLL RUNS (مسيرات الرواتب) ============
// مسير الرواتب يجمع عدة موظفين لفترة شهرية معينة.
// المصدر الوحيد للحقيقة في قيود الرواتب هو JournalEntry المرتبط عبر journalEntryId.

model PayrollRun {
  id                   String           @id @default(cuid())
  code                 String           @unique // PAY-YYYY-NNNN
  month                Int              // 1-12
  year                 Int
  status               PayrollRunStatus @default(DRAFT)
  totalAmount          Decimal          @default(0) // إجمالي الاستحقاق
  totalDeductions      Decimal          @default(0) // إجمالي الخصومات
  totalGosi            Decimal          @default(0) // إجمالي التأمينات
  totalNet             Decimal          @default(0) // إجمالي الصافي
  notes                String?
  journalEntryId       String?          // قيد الاستحقاق (مدين 8110/7120/7210 / دائن 3310)
  paymentJournalEntryId String?         // قيد الدفع (مدين 3310 / دائن البنك/الصندوق)
  paymentAccountCode   String?          // كود الحساب الذي تم الدفع منه (بنك/صندوق)
  paymentAccountNameAr String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  lines           PayrollRunLine[]
  salaryPayments  SalaryPayment[]

  @@index([month, year])
  @@index([status])
  @@index([year])
  @@unique([year, month])
}

model PayrollRunLine {
  id                 String     @id @default(cuid())
  payrollRunId       String
  employeeId         String
  projectId          String?    // ربط سطر المسير بمشروع معين
  workTeamId         String?    // ربط سطر المسير بفريق عمل
  salaryType         SalaryType // MONTHLY أو HOURLY
  basicSalary        Decimal    @default(0) // الراتب الأساسي (للشهريين)
  housingAllowance   Decimal    @default(0) // بدل السكن
  transportAllowance Decimal    @default(0) // بدل النقل
  otherAllowances    Decimal    @default(0) // بدلات أخرى
  hourlyRate         Decimal    @default(0) // معدل الساعة (للساعيين)
  workHours          Decimal    @default(0) // عدد الساعات (للساعيين)
  hourlySalary       Decimal    @default(0) // أجر الساعات = hourlyRate * workHours
  overtimeAmount     Decimal    @default(0) // حوافز/عمل إضافي
  deductions         Decimal    @default(0) // الخصومات
  gosiDeduction      Decimal    @default(0) // استقطاع التأمينات
  totalEntitlement   Decimal    @default(0) // إجمالي الاستحقاق
  netSalary          Decimal    @default(0) // الصافي
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workTeam   WorkTeam?  @relation(fields: [workTeamId], references: [id], onDelete: SetNull)

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([projectId])
  @@index([workTeamId])
  @@index([salaryType])
}

model SalaryPayment {
  id              String   @id @default(cuid())
  payrollRunId    String?
  employeeId      String
  amount          Decimal  @default(0)
  paymentDate     DateTime @default(now())
  paymentMethod   String   @default("BANK_TRANSFER") // BANK_TRANSFER | CASH | CHEQUE
  reference       String?  // رقم مرجعي (رقم التحويل، رقم الشيك)
  notes           String?
  journalEntryId  String?  // قيد سداد الراتب (مدين 3310 / دائن البنك/الصندوق)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([payrollRunId])
  @@index([employeeId])
  @@index([paymentDate])
}

// ============ PROJECTS ============

model Project {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  nameAr        String?
  location      String?
  branchId      String
  clientId      String
  costCenterId  String?       // مركز التكلفة المرتبط للمشروع — رابط مباشر لقيود اليومية
  projectType   ProjectType   @default(CONSTRUCTION)
  startDate     DateTime
  endDate       DateTime?
  contractValue Decimal       @default(0)
  status        ProjectStatus @default(PLANNING)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch                 Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  client                 Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  costCenter             CostCenter?              @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  contracts              Contract[]
  boqItems               BOQItem[]
  changeOrders           ChangeOrder[]
  warranties             Warranty[]
  progressClaims         ProgressClaim[]
  salesInvoices          SalesInvoice[]
  purchaseOrders         PurchaseOrder[]
  purchaseRequests       PurchaseRequest[]
  expenses               Expense[]
  laborCosts             LaborCost[]
  equipmentCosts         EquipmentCost[]
  equipmentUsages        EquipmentUsage[]
  subcontractorInvoices  SubcontractorInvoice[]
  subcontractorContracts SubcontractorContract[]
  timesheets             Timesheet[]
  rentalContracts        EquipmentRental[]
  workTeams              WorkTeam[]
  goodsReceipts          GoodsReceipt[]
  purchaseInvoices       PurchaseInvoice[]
  fuelLogs               EquipmentFuelLog[]
  resourceAllocations    ResourceAllocation[]
  equipmentOperations    EquipmentOperation[]
  salaries               Salary[]
  deliveryOrders         EquipmentDeliveryOrder[]
  payrollLines           PayrollRunLine[]
  // ── Phase 1-2 relations ──
  wbsElements            WBSElement[]
  activities             Activity[]
  costEntries            CostEntry[]
  projectLedger          ProjectLedger[]
  commitments            Commitment[]
  subcontractorAdvances  SubcontractorAdvance[]
  subcontractorRetentions SubcontractorRetention[]
  measurements           Measurement[]
  wipEntries             WIPEntry[]
  wipAdjustments         WIPAdjustment[]
  projectBudgets         ProjectBudget[]
  projectForecasts       ProjectForecast[]
  lossProvisions         LossProvision[]
  customerAdvances       CustomerAdvance[]
  estimatedTotalCost     Decimal?  @default(0)
  committedCost          Decimal?  @default(0)
  actualCost             Decimal?  @default(0)
  progressPercent        Decimal?  @default(0)
  deletedAt              DateTime?  // P2-CRIT-009 fix: soft-delete support

  @@index([branchId])
  @@index([clientId])
  @@index([costCenterId])
  @@index([status])
  @@index([projectType])
  @@index([clientId, status])
}

// ============ CONTRACTS ============
// عقد موحد يدعم نوعين: مشاريع تنفيذية وتأجير معدات

model Contract {
  id                    String         @id @default(cuid())
  projectId             String
  contractNo            String         @unique
  date                  DateTime
  value                 Decimal        @default(0)
  vatRate               Decimal        @default(0.15)
  vatAmount             Decimal        @default(0)
  totalValue            Decimal        @default(0)
  startDate             DateTime
  endDate               DateTime?
  status                ContractStatus @default(DRAFT)
  description           String?
  // ─── Contract Type ───
  contractType          String         @default("PROJECT") // PROJECT, RENTAL, SERVICE
  // ─── Rental Contract Fields ───
  clientId              String?
  equipmentId           String?
  hourlyRate            Decimal?
  deliveryFees          Decimal        @default(0)
  deliveryFeesTaxable   Boolean        @default(true)
  paymentTerms          String?
  salesOrderNo          String?
  journalEntryId        String?
  // ─── Project Contract Fields ───
  quotationNo           String? // رقم عرض السعر
  loaNo                 String? // رقم أمر الترسية
  purchaseOrderNo       String? // رقم أمر الشراء PO
  projectDuration       String? // مدة المشروع
  warrantyPeriod        String? // مدة الضمان
  maintenancePeriod     String? // مدة الصيانة
  billingMethod         String? // PROGRESS_CLAIMS, MILESTONES
  firstClaimNo          String? // رقم أول مستخلص
  advancePaymentPercent Decimal?       @default(0) // نسبة الدفعة المقدمة
  retentionPercent      Decimal?       @default(0) // نسبة الاستقطاع
  projectManager        String? // مدير المشروع
  projectEngineer       String? // مهندس المشروع
  projectLocation       String? // الموقع
  projectCity           String? // المدينة
  projectType           String? // RESIDENTIAL, COMMERCIAL, GOVERNMENT, INFRASTRUCTURE, MAINTENANCE_OPS
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  progressClaims ProgressClaim[]
  salesInvoices  SalesInvoice[]
  changeOrders   ChangeOrder[]
  warranties     Warranty[]
  timesheets     Timesheet[]
  rental         EquipmentRental?

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([contractType])
  @@index([projectId, status])
  @@index([date])
}

// ============ CHANGE ORDERS / VARIATION ORDERS ============
// أوامر التغيير - لإدارة التعديلات على العقود

model ChangeOrder {
  id              String            @id @default(cuid())
  projectId       String
  contractId      String
  orderNo         String            @unique
  date            DateTime
  description     String
  changeType      String            @default("ADDITION") // ADDITION, MODIFICATION, DELETION
  originalValue   Decimal           @default(0)
  changeValue     Decimal           @default(0)
  newValue        Decimal           @default(0)
  vatRate         Decimal           @default(0.15)
  vatAmount       Decimal           @default(0)
  totalChangeValue Decimal          @default(0)
  status          ChangeOrderStatus @default(DRAFT)
  approvedDate    DateTime?
  approvedBy      String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([contractId])
  @@index([status])
  @@index([date])
}

// ============ WARRANTIES ============
// الضمانات

model Warranty {
  id             String       @id @default(cuid())
  projectId      String
  contractId     String
  type           WarrantyType @default(PERFORMANCE)
  referenceNo    String?      @unique
  issuer         String?      // جهة الإصدار (بنك/شركة تأمين)
  beneficiary    String?      // المستفيد
  amount         Decimal      @default(0)
  startDate      DateTime
  endDate        DateTime
  status         String       @default("ACTIVE") // ACTIVE, RELEASED, EXPIRED, CLAIMED
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([contractId])
  @@index([status])
  @@index([endDate])
}

// ============ BOQ ============

model BOQItem {
  id          String   @id @default(cuid())
  projectId   String
  code        String
  description String
  unit        String
  quantity    Decimal  @default(0)
  unitPrice   Decimal  @default(0)
  totalPrice  Decimal  @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  // ── Phase 2 relations ──
  wbsElement   WBSElement?   @relation(fields: [wbsElementId], references: [id], onDelete: SetNull)
  measurements Measurement[]
  claimItems   ClaimItem[]
  wbsElementId String?

  @@index([projectId])
  @@index([code])
  @@index([wbsElementId])
}

// ============ PROGRESS CLAIMS ============

model ProgressClaim {
  id             String      @id @default(cuid())
  projectId      String
  contractId     String
  claimNo        String      @unique
  date           DateTime
  percentage     Decimal     @default(0)
  amount         Decimal     @default(0)
  vatRate        Decimal     @default(0.15)
  vatAmount      Decimal     @default(0)
  totalAmount    Decimal     @default(0)
  status         ClaimStatus @default(DRAFT)
  approvedDate   DateTime?
  notes          String?
  journalEntryId String?
  invoiced       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  // ── Phase 2 fields ──
  certifiedAmount   Decimal? @default(0)
  retentionAmount   Decimal? @default(0)
  advanceDeduction  Decimal? @default(0)

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  contract     Contract      @relation(fields: [contractId], references: [id], onDelete: Restrict)
  salesInvoice SalesInvoice?
  // ── Phase 2 relations ──
  items        ClaimItem[]
  certification ClaimCertification?

  @@index([projectId])
  @@index([contractId])
  @@index([status])
  @@index([date])
  @@index([projectId, status])
}

// ============ SALES / CLIENT INVOICES ============

model SalesInvoice {
  id                  String        @id @default(cuid())
  invoiceNo           String        @unique
  projectId           String?
  contractId          String?
  clientId            String
  date                DateTime
  dueDate             DateTime
  subtotal            Decimal       @default(0)
  discountRate        Decimal       @default(0)
  discountAmount      Decimal       @default(0)
  netAmount           Decimal       @default(0)
  vatRate             Decimal       @default(0.15)
  vatAmount           Decimal       @default(0)
  totalAmount         Decimal       @default(0)
  paidAmount          Decimal       @default(0)
  status              InvoiceStatus @default(DRAFT)
  invoiceType         String        @default("PROGRESS_CLAIM") // PROGRESS_CLAIM, RENTAL, SERVICE
  notes               String?
  paymentTerms        String?
  referenceNo         String?
  sourceType          String        @default("EXTRACT") // EXTRACT or TIMESHEET
  timesheetId         String?       @unique
  progressClaimId     String?       @unique
  deliveryMonth       String?
  includeDelivery     Boolean       @default(false)
  deliveryAmount      Decimal       @default(0)
  deliveryFeesTaxable Boolean       @default(true)
  includeVat          Boolean       @default(true)
  contractNo          String?
  contractType        String?
  contractPeriodStart DateTime?
  contractPeriodEnd   DateTime?
  salesOrderNo        String?
  equipmentName       String?
  operatingHours      Decimal?
  hourlyRate          Decimal?
  amountInWordsAr     String?
  amountInWordsEn     String?
  journalEntryId      String?
  // ZATCA QR fields
  zatcaQr             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  project        Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contract       Contract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  items          SalesInvoiceItem[]
  timesheet      Timesheet?         @relation(fields: [timesheetId], references: [id], onDelete: SetNull)
  progressClaim  ProgressClaim?     @relation(fields: [progressClaimId], references: [id], onDelete: SetNull)
  clientPayments ClientPayment[]

  @@index([projectId])
  @@index([contractId])
  @@index([clientId])
  @@index([status])
  @@index([date])
  @@index([clientId, status])
  @@index([projectId, status])
  @@index([invoiceType])
}

model SalesInvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  description   String
  descriptionEn String?
  quantity      Decimal  @default(0)
  unit          String?
  unitPrice     Decimal  @default(0)
  totalPrice    Decimal  @default(0)
  itemType      String   @default("PRODUCT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============ PURCHASE WORKFLOW ============

model PurchaseRequest {
  id          String                @id @default(cuid())
  requestNo   String                @unique
  projectId   String?
  source      String                @default("PROJECT") // PROJECT, INVENTORY, WORKSHOP, ADMIN
  date        DateTime
  description String?
  status      PurchaseRequestStatus @default(NEW)
  requestedBy String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  project        Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items          PurchaseRequestItem[]
  purchaseOrders PurchaseOrder[]

  @@index([projectId])
  @@index([status])
  @@index([date])
}

model PurchaseRequestItem {
  id          String   @id @default(cuid())
  requestId   String
  description String
  quantity    Decimal  @default(0)
  unit        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  orderNo           String              @unique
  projectId         String?
  supplierId        String
  purchaseRequestId String?
  date              DateTime
  deliveryDate      DateTime?
  paymentTerms      String?
  subtotal          Decimal             @default(0)
  vatRate           Decimal             @default(0.15)
  vatAmount         Decimal             @default(0)
  totalAmount       Decimal             @default(0)
  paidAmount        Decimal             @default(0)
  status            PurchaseOrderStatus @default(DRAFT)
  notes             String?
  journalEntryId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  project         Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseRequest PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  items           PurchaseOrderItem[]
  invoices        PurchaseInvoice[]
  goodsReceipts   GoodsReceipt[]

  @@index([projectId])
  @@index([supplierId])
  @@index([purchaseRequestId])
  @@index([status])
  @@index([date])
  @@index([supplierId, status])
  @@index([projectId, status])
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  description String
  quantity    Decimal  @default(0)
  unit        String?
  unitPrice   Decimal  @default(0)
  vatRate     Decimal  @default(0.15)
  totalPrice  Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  receiptNo       String             @unique
  purchaseOrderId String
  supplierId      String
  projectId       String?
  date            DateTime
  status          GoodsReceiptStatus @default(PENDING)
  notes           String?
  journalEntryId  String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  supplier        Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  project         Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items           GoodsReceiptItem[]
  purchaseInvoice PurchaseInvoice?

  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([projectId])
  @@index([status])
  @@index([date])
}

model GoodsReceiptItem {
  id                String   @id @default(cuid())
  goodsReceiptId    String
  description       String
  quantityOrdered   Decimal  @default(0)
  quantityReceived  Decimal  @default(0)
  quantityRemaining Decimal  @default(0)
  unitPrice         Decimal  @default(0)
  totalPrice        Decimal  @default(0)
  destination       String   @default("INVENTORY") // INVENTORY or PROJECT
  inventoryItemId   String?  // explicit link to InventoryItem (P5-CRIT-013 fix)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
  @@index([inventoryItemId])
}

model PurchaseInvoice {
  id                  String        @id @default(cuid())
  invoiceNo           String        @unique
  purchaseOrderId     String?
  goodsReceiptId      String?       @unique
  projectId           String?
  equipmentId         String? // ربط بالمعدة
  activityType        String        @default("EXECUTION") // EXECUTION, RENTAL, GENERAL
  supplierId          String
  date                DateTime
  dueDate             DateTime
  supplierInvoiceNo   String?
  supplierInvoiceDate DateTime?
  attachmentPath      String?
  subtotal            Decimal       @default(0)
  vatRate             Decimal       @default(0.15)
  vatAmount           Decimal       @default(0)
  totalAmount         Decimal       @default(0)
  paidAmount          Decimal       @default(0)
  status              InvoiceStatus @default(DRAFT)
  notes               String?
  referenceNo         String?
  expenseCategory     String?
  journalEntryId      String?
  // ZATCA QR fields
  zatcaQr             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  purchaseOrder PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  goodsReceipt  GoodsReceipt?         @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)
  supplier      Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  project       Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  equipment     Equipment?            @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  items         PurchaseInvoiceItem[]

  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
  @@index([supplierId])
  @@index([projectId])
  @@index([equipmentId])
  @@index([status])
  @@index([date])
  @@index([supplierId, status])
}

model PurchaseInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @default(0)
  unitPrice   Decimal  @default(0)
  totalPrice  Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============ SUBCONTRACTOR CONTRACTS ============

model SubcontractorContract {
  id              String         @id @default(cuid())
  subcontractorId String
  projectId       String
  contractNo      String         @unique
  startDate       DateTime
  endDate         DateTime?
  value           Decimal        @default(0)
  vatRate         Decimal        @default(0.15)
  vatAmount       Decimal        @default(0)
  totalValue      Decimal        @default(0)
  retentionRate   Decimal        @default(0)
  status          ContractStatus @default(DRAFT)
  description     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@index([subcontractorId])
  @@index([projectId])
  @@index([status])
  @@index([projectId, status])
}

// ============ SUBCONTRACTOR INVOICES ============

model SubcontractorInvoice {
  id              String        @id @default(cuid())
  subcontractorId String
  projectId       String?
  invoiceNo       String        @unique
  date            DateTime
  amount          Decimal       @default(0)
  vatRate         Decimal       @default(0.15)
  vatAmount       Decimal       @default(0)
  totalAmount     Decimal       @default(0)
  paidAmount      Decimal       @default(0)
  status          InvoiceStatus @default(DRAFT)
  description     String?
  journalEntryId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // ── Phase 2 relations ──
  payments     SubcontractorPayment[]

  @@index([subcontractorId])
  @@index([projectId])
  @@index([status])
  @@index([date])
  @@index([subcontractorId, status])
}

// ============ EXPENSES ============

model Expense {
  id             String          @id @default(cuid())
  projectId      String?
  equipmentId    String? // ربط بالمعدة
  costCenterId   String? // مركز التكلفة (يُربط بقيد اليومية)
  expenseType    ExpenseType     @default(PROJECT)
  activityType   String          @default("EXECUTION") // EXECUTION, RENTAL, GENERAL
  category       ExpenseCategory
  description    String
  amount         Decimal         @default(0)
  vatRate        Decimal         @default(0.15)
  vatAmount      Decimal         @default(0)
  totalAmount    Decimal         @default(0)
  date           DateTime
  reference      String?
  payFrom        String          @default("TREASURY")
  attachmentPath String?
  journalEntryId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  equipment  Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  costCenter CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([equipmentId])
  @@index([costCenterId])
  @@index([category])
  @@index([date])
  @@index([expenseType])
}

// ============ LABOR COSTS ============

model LaborCost {
  id              String   @id @default(cuid())
  projectId       String
  employeeId      String?  // ربط بالموظف
  description     String
  workers         Int
  days            Decimal  @default(0)
  dailyRate       Decimal  @default(0)
  totalAmount     Decimal  @default(0)
  date            DateTime
  journalEntryId  String?  // JE link (P4-CRIT-005) — Dr PROJECT_COST (with costCenterId) / Cr CASH
  // === تفاصيل يختارها المستخدم (المستخدم سيد النظام) ===
  // مصدر الدفع: بنك / نقدية (يحترم اختيار المستخدم بدل الإجبار على النقدية)
  paymentSource      String? // 'BANK' | 'CASH'
  paymentAccountCode String? // كود الحساب الدائن الفعلي المستخدم في القيد
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([employeeId])
  @@index([date])
}

// ============ EQUIPMENT ============

model Equipment {
  id              String              @id @default(cuid())
  code            String              @unique
  name            String
  nameAr          String?
  type            String?
  model           String?
  manufacturer    String?
  manufactureYear Int?
  plateNumber     String?
  serialNumber    String?
  status          EquipmentStatus     @default(AVAILABLE)
  // ─── Ownership ───
  ownershipType   EquipmentOwnershipType @default(COMPANY_OWNED)
  supplierId      String?             // المورد (اختياري للشركة المملوكة، إلزامي للمستأجرة)
  ownerId         String?             // مالك المعدة (للمعدات المملوكة للعميل)
  purchasePrice   Decimal             @default(0)
  sellingPrice    Decimal             @default(0)
  hourlyRate      Decimal             @default(0)
  dailyRate       Decimal             @default(0)
  monthlyRate     Decimal             @default(0)
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  assetAccountId  String?             // حساب الأصل الثابت
  assetAccountCode String?            // كود حساب الأصل (للعرض السريع)
  isActive        Boolean             @default(true)
  deletedAt       DateTime?
  journalEntryId String?             // JE for equipment purchase (Dr EQUIPMENT_ASSET / Cr CASH or AP)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  supplier         Supplier?                @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  assetAccount     Account?                 @relation("EquipmentAssetAccount", fields: [assetAccountId], references: [id], onDelete: SetNull)
  usages           EquipmentUsage[]
  maintenance      EquipmentMaintenance[]
  fuelLogs         EquipmentFuelLog[]
  rentals          EquipmentRental[]
  expenses         EquipmentExpense[]
  deliveryOrders   EquipmentDeliveryOrder[]
  timesheets       Timesheet[]
  operatorLogs     EquipmentOperation[]
  purchaseInvoices PurchaseInvoice[]
  costExpenses     Expense[] // المصروفات المرتبطة بالمعدة

  @@index([supplierId])
  @@index([assetAccountId])
  @@index([status])
  @@index([isActive])
  @@index([ownershipType])
}

