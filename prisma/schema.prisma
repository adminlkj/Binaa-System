// ============ EQUIPMENT RENTAL ============

model EquipmentRental {
  id                      String    @id @default(cuid())
  contractId              String    @unique
  equipmentId             String
  clientId                String
  projectId               String?
  startDate               DateTime
  endDate                 DateTime?
  // ─── Pricing ───
  pricingType             String    @default("HOURLY") // HOURLY, DAILY, MONTHLY, LUMP_SUM
  referenceRate           Decimal   @default(0) // القيمة الشهرية المرجعية
  referenceHours          Decimal   @default(0) // ساعات التسعير المرجعية
  hourlyRate              Decimal   @default(0) // محسوب تلقائياً
  dailyRate               Decimal   @default(0) // السعر اليومي
  monthlyRate             Decimal   @default(0) // السعر الشهري
  lumpSumAmount           Decimal   @default(0) // المبلغ المقطوع
  // ─── Work Location ───
  workCity                String? // مدينة المشروع
  workLocation            String? // موقع العمل
  siteSupervisor          String? // اسم المسؤول بالموقع
  siteSupervisorPhone     String? // جوال المسؤول
  // ─── Delivery & Transport ───
  deliveryFeesType        String?   @default("NONE") // NONE, FIXED, ONE_WAY, ROUND_TRIP, BY_DISTANCE
  deliveryFees            Decimal   @default(0)
  deliveryFeesTaxable     Boolean   @default(true)
  // ─── Operation & Responsibilities ───
  operationMode           String    @default("WITHOUT_DRIVER") // WITHOUT_DRIVER, WITH_DRIVER, WITH_CREW
  fuelResponsibility      String?   @default("ON_CLIENT") // ON_CLIENT, ON_COMPANY
  insuranceResponsibility String?   @default("ON_CLIENT") // ON_CLIENT, ON_COMPANY
  // ─── Reference Documents ───
  salesOrderNo            String? // رقم طلب البيع (تلقائي)
  purchaseOrderNo         String? // رقم طلب شراء العميل
  quotationNo             String? // رقم عرض السعر
  // ─── Status & Terms ───
  status                  String    @default("DRAFT") // DRAFT, UNDER_REVIEW, ACTIVE, EXPIRED, CANCELLED
  paymentDuration         String? // مدة السداد بالأيام
  additionalTerms         String? // شروط إضافية
  notes                   String?
  totalAmount             Decimal   @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  contract       Contract                 @relation(fields: [contractId], references: [id], onDelete: Restrict)
  equipment      Equipment                @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  client         Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project        Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliveryOrders EquipmentDeliveryOrder[]
  timesheets     Timesheet[]

  @@index([contractId])
  @@index([equipmentId])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([clientId, status])
  @@index([equipmentId, status])
}

model EquipmentDeliveryOrder {
  id           String              @id @default(cuid())
  orderNo      String              @unique
  rentalId     String?
  equipmentId  String
  clientId     String?
  projectId    String?
