// نظام بِنَاء ERP - Complete Schema
// Binaa Construction ERP
// Updated: Resources + Supply Chain + Accounting Integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PurchaseRequestStatus {
  NEW
  APPROVED
  CONVERTED_TO_PO
  CANCELLED
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_PAID
  PAID
  REJECTED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  OUT_OF_SERVICE
  RENTED
}

enum AdvanceStatus {
  PENDING
  PARTIALLY_SETTLED
  SETTLED
  CANCELLED
}

enum InventoryItemType {
  PRODUCT
  SERVICE
}

enum ProjectType {
  CONSTRUCTION
  EQUIPMENT_RENTAL
}

enum ExpenseType {
  PROJECT
  INTERNAL
}

enum ExpenseCategory {
  RENT
  MAINTENANCE
  TRANSPORT
  DELIVERY
  CONSUMABLES
  SERVICES
  INSURANCE
  FUEL
  PERMITS
  OFFICE
  HOSPITALITY
  OTHER
  SALARIES
  INTERNET
  ELECTRICITY
  WATER
  MANAGEMENT_CARS
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  INVOICED
}

enum DeliveryOrderStatus {
  PENDING
  DELIVERED
  RETURNED
  CANCELLED
}

enum VATReturnStatus {
  DRAFT
  FILED
  PAID
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
}

enum SalaryStatus {
  DRAFT
  APPROVED
  PAID
}

enum GoodsReceiptStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

// ============ COMPANY SETTINGS ============

model CompanySetting {
  id              String   @id @default(cuid())
  nameAr          String
  nameEn          String
  logo            String?
  logoUrl         String?
  commercialReg   String?
  taxNumber       String?
  address         String?
  phone           String?
  email           String?
  website         String?
  bankName        String?
  bankIban        String?
  bankAccountName String?
  stamp           String?
  defaultVatRate  Float    @default(0.15)
  currency        String   @default("SAR")
  currencySymbol    String?
  currencySymbolEn  String?
  currencySymbolAr  String?
  invoiceTerms    String?
  currencySymbolImage String?
  headerImage         String?
  footerImage         String?
  useThousandSeparatorsSystem  Boolean  @default(true)
  useThousandSeparatorsOfficial Boolean @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============ CORE / SETTINGS ============

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects     Project[]
  warehouses   Warehouse[]
  employees    Employee[]
  pettyCashes  PettyCash[]
}

model Warehouse {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  branchId String
  isActive Boolean @default(true)

  branch         Branch       @relation(fields: [branchId], references: [id])
  inventoryItems InventoryItem[]
}

model CostCenter {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  parentId String?

  parent    CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostCenterHierarchy")
  journalLines JournalLine[]
}

model Attachment {
  id         String   @id @default(cuid())
  entityId   String
  entityType String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

// ============ CLIENTS & SUPPLIERS ============

model Client {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  nameEn        String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects      Project[]
  salesInvoices SalesInvoice[]
  rentalContracts EquipmentRental[]
  deliveryOrders EquipmentDeliveryOrder[]
}

model Supplier {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  nameAr          String?
  nameEn          String?
  contactPerson   String?
  email           String?
  phone           String?
  address         String?
  taxNumber       String?
  commercialReg   String?
  paymentTerms    String?
  creditLimit     Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  equipment       Equipment[]
  goodsReceipts   GoodsReceipt[]
  supplierPayments SupplierPayment[]
  equipmentMaintenance EquipmentMaintenance[]
}

model Subcontractor {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  nameAr        String?
  nameEn        String?
  specialty     String?
  idOrRegNumber String?
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  taxNumber     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices SubcontractorInvoice[]
  contracts SubcontractorContract[]
}

// ============ EMPLOYEES ============

model Employee {
  id                String         @id @default(cuid())
  code              String         @unique
  name              String
  nameAr            String?
  nationality       String?
  profession        String?
  residenceNumber   String?
  residenceExpiry   DateTime?
  hireDate          DateTime?
  basicSalary       Float          @default(0)
  status            EmployeeStatus @default(ACTIVE)
  branchId          String
  phone             String?
  email             String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  branch           Branch            @relation(fields: [branchId], references: [id])
  advances         EmployeeAdvance[]
  contracts        EmployeeContract[]
  attendance       Attendance[]
  salaries         Salary[]
  teamMemberships  TeamMember[]
  operatorLogs     EquipmentOperation[]
}

model EmployeeContract {
  id              String   @id @default(cuid())
  employeeId      String
  startDate       DateTime
  endDate         DateTime?
  basicSalary     Float
  housingAllowance Float   @default(0)
  transportAllowance Float @default(0)
  otherAllowances Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id           String   @id @default(cuid())
  employeeId   String
  date         DateTime
  checkIn      DateTime?
  checkOut     DateTime?
  workHours    Float    @default(0)
  overtimeHours Float   @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Salary {
  id              String       @id @default(cuid())
  employeeId      String
  month           Int          // 1-12
  year            Int
  basicSalary     Float
  housingAllowance Float      @default(0)
  transportAllowance Float    @default(0)
  otherAllowances Float       @default(0)
  overtimeAmount  Float       @default(0)
  deductions      Float       @default(0)
  netSalary       Float       @default(0)
  status          SalaryStatus @default(DRAFT)
  journalEntryId  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model WorkTeam {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nameAr      String?
  specialty   String?
  projectId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project?     @relation(fields: [projectId], references: [id])
  members     TeamMember[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  employeeId String
  role      String?
  isLeader  Boolean  @default(false)
  createdAt DateTime @default(now())

  team     WorkTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ PROJECTS ============

model Project {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  nameAr        String?
  location      String?
  branchId      String
  clientId      String
  projectType   ProjectType   @default(CONSTRUCTION)
  startDate     DateTime
  endDate       DateTime?
  contractValue Float         @default(0)
  status        ProjectStatus @default(PLANNING)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch         Branch           @relation(fields: [branchId], references: [id])
  client         Client           @relation(fields: [clientId], references: [id])
  contracts      Contract[]
  boqItems       BOQItem[]
  progressClaims ProgressClaim[]
  salesInvoices  SalesInvoice[]
  purchaseOrders PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  expenses       Expense[]
  laborCosts     LaborCost[]
  equipmentCosts EquipmentCost[]
  equipmentUsages EquipmentUsage[]
  subcontractorInvoices SubcontractorInvoice[]
  timesheets     Timesheet[]
  workTeams      WorkTeam[]
  goodsReceipts  GoodsReceipt[]
  purchaseInvoices PurchaseInvoice[]
  fuelLogs       EquipmentFuelLog[]
  resourceAllocations ResourceAllocation[]
  equipmentOperations EquipmentOperation[]
}

model Contract {
  id              String         @id @default(cuid())
  projectId       String
  contractNo      String         @unique
  date            DateTime
  value           Float
  vatRate         Float          @default(0.15)
  vatAmount       Float          @default(0)
  totalValue      Float          @default(0)
  startDate       DateTime
  endDate         DateTime?
  status          ContractStatus @default(DRAFT)
  description     String?
  contractType    String?
  clientId        String?
  equipmentId     String?
  hourlyRate      Float?
  deliveryFees    Float          @default(0)
  deliveryFeesTaxable Boolean    @default(true)
  paymentTerms    String?
  salesOrderNo    String?
  journalEntryId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project        Project        @relation(fields: [projectId], references: [id])
  progressClaims ProgressClaim[]
  salesInvoices  SalesInvoice[]
  timesheets     Timesheet[]
  rental         EquipmentRental?
}

// ============ BOQ ============

model BOQItem {
  id          String   @id @default(cuid())
  projectId   String
  code        String
  description String
  unit        String
  quantity    Float
  unitPrice   Float
  totalPrice  Float
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

// ============ PROGRESS CLAIMS ============

model ProgressClaim {
  id            String      @id @default(cuid())
  projectId     String
  contractId    String
  claimNo       String
  date          DateTime
  percentage    Float
  amount        Float
  vatRate       Float       @default(0.15)
  vatAmount     Float       @default(0)
  totalAmount   Float       @default(0)
  status        ClaimStatus @default(DRAFT)
  approvedDate  DateTime?
  notes         String?
  journalEntryId String?
  invoiced      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project      Project       @relation(fields: [projectId], references: [id])
  contract     Contract      @relation(fields: [contractId], references: [id])
  salesInvoice SalesInvoice?
}

// ============ SALES / CLIENT INVOICES ============

model SalesInvoice {
  id            String        @id @default(cuid())
  invoiceNo     String        @unique
  projectId     String?
  contractId    String?
  clientId      String
  date          DateTime
  dueDate       DateTime
  subtotal      Float
  discountRate  Float         @default(0)
  discountAmount Float        @default(0)
  netAmount     Float         @default(0)
  vatRate       Float         @default(0.15)
  vatAmount     Float
  totalAmount   Float
  paidAmount    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  invoiceType   String        @default("PROGRESS_CLAIM")
  notes         String?
  paymentTerms  String?
  referenceNo   String?
  sourceType    String        @default("EXTRACT")  // EXTRACT or TIMESHEET
  timesheetId   String?       @unique
  progressClaimId String?     @unique
  deliveryMonth String?
  includeDelivery Boolean     @default(false)
  deliveryAmount Float        @default(0)
  deliveryFeesTaxable Boolean @default(true)
  includeVat    Boolean       @default(true)
  contractNo    String?
  contractType  String?
  contractPeriodStart DateTime?
  contractPeriodEnd   DateTime?
  salesOrderNo  String?
  equipmentName String?
  operatingHours Float?
  hourlyRate    Float?
  amountInWordsAr String?
  amountInWordsEn String?
  journalEntryId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project       Project?       @relation(fields: [projectId], references: [id])
  contract      Contract?      @relation(fields: [contractId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  items         SalesInvoiceItem[]
  timesheet     Timesheet?     @relation(fields: [timesheetId], references: [id])
  progressClaim ProgressClaim? @relation(fields: [progressClaimId], references: [id])
}

model SalesInvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  description   String
  descriptionEn String?
  quantity      Float
  unit          String?
  unitPrice     Float
  totalPrice    Float
  itemType      String   @default("PRODUCT")

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ PURCHASE WORKFLOW ============

model PurchaseRequest {
  id          String              @id @default(cuid())
  requestNo   String              @unique
  projectId   String?
  source      String              @default("PROJECT") // PROJECT, INVENTORY, WORKSHOP, ADMIN
  date        DateTime
  description String?
  status      PurchaseRequestStatus @default(NEW)
  requestedBy String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  items   PurchaseRequestItem[]
  purchaseOrders PurchaseOrder[]
}

model PurchaseRequestItem {
  id          String   @id @default(cuid())
  requestId   String
  description String
  quantity    Float
  unit        String?
  notes       String?

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  orderNo           String              @unique
  projectId         String?
  supplierId        String
  purchaseRequestId String?
  date              DateTime
  deliveryDate      DateTime?
  paymentTerms      String?
  subtotal          Float
  vatRate           Float               @default(0.15)
  vatAmount         Float
  totalAmount       Float
  paidAmount        Float               @default(0)
  status            PurchaseOrderStatus @default(DRAFT)
  notes             String?
  journalEntryId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  project         Project?         @relation(fields: [projectId], references: [id])
  supplier        Supplier         @relation(fields: [supplierId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  items           PurchaseOrderItem[]
  invoices        PurchaseInvoice[]
  goodsReceipts   GoodsReceipt[]
}

model PurchaseOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  description String
  quantity    Float
  unit        String?
  unitPrice   Float
  vatRate     Float    @default(0.15)
  totalPrice  Float

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model GoodsReceipt {
  id             String             @id @default(cuid())
  receiptNo      String             @unique
  purchaseOrderId String
  supplierId     String
  projectId      String?
  date           DateTime
  status         GoodsReceiptStatus @default(PENDING)
  notes          String?
  journalEntryId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
  items         GoodsReceiptItem[]
  purchaseInvoice PurchaseInvoice?
}

model GoodsReceiptItem {
  id              String   @id @default(cuid())
  goodsReceiptId  String
  description     String
  quantityOrdered Float
  quantityReceived Float
  quantityRemaining Float
  unitPrice       Float
  totalPrice      Float
  destination     String   @default("INVENTORY") // INVENTORY or PROJECT

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
}

model PurchaseInvoice {
  id               String        @id @default(cuid())
  invoiceNo        String        @unique
  purchaseOrderId  String?
  goodsReceiptId   String?          @unique
  projectId        String?
  supplierId       String
  date             DateTime
  dueDate          DateTime
  supplierInvoiceNo String?
  supplierInvoiceDate DateTime?
  attachmentPath   String?
  subtotal         Float
  vatRate          Float         @default(0.15)
  vatAmount        Float
  totalAmount      Float
  paidAmount       Float         @default(0)
  status           InvoiceStatus @default(DRAFT)
  notes            String?
  referenceNo      String?
  expenseCategory  String?
  journalEntryId   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  purchaseOrder PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  goodsReceipt  GoodsReceipt?   @relation(fields: [goodsReceiptId], references: [id])
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  project       Project?        @relation(fields: [projectId], references: [id])
  items         PurchaseInvoiceItem[]
}

model PurchaseInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ============ SUBCONTRACTOR CONTRACTS ============

model SubcontractorContract {
  id              String   @id @default(cuid())
  subcontractorId String
  projectId       String
  contractNo      String   @unique
  startDate       DateTime
  endDate         DateTime?
  value           Float
  vatRate         Float    @default(0.15)
  vatAmount       Float    @default(0)
  totalValue      Float    @default(0)
  retentionRate   Float    @default(0)
  status          ContractStatus @default(DRAFT)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
}

// ============ SUBCONTRACTOR INVOICES ============

model SubcontractorInvoice {
  id              String        @id @default(cuid())
  subcontractorId String
  projectId       String?
  invoiceNo       String        @unique
  date            DateTime
  amount          Float
  vatRate         Float         @default(0.15)
  vatAmount       Float
  totalAmount     Float
  paidAmount      Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  description     String?
  journalEntryId  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  project       Project?      @relation(fields: [projectId], references: [id])
}

// ============ EXPENSES ============

model Expense {
  id               String          @id @default(cuid())
  projectId        String?
  expenseType      ExpenseType     @default(PROJECT)
  category         ExpenseCategory
  description      String
  amount           Float
  vatRate          Float           @default(0.15)
  vatAmount        Float           @default(0)
  totalAmount      Float           @default(0)
  date             DateTime
  reference        String?
  payFrom          String          @default("TREASURY")
  attachmentPath   String?
  journalEntryId   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
}

// ============ LABOR COSTS ============

model LaborCost {
  id          String   @id @default(cuid())
  projectId   String
  description String
  workers     Int
  days        Float
  dailyRate   Float
  totalAmount Float
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

// ============ EQUIPMENT ============

model Equipment {
  id               String          @id @default(cuid())
  code             String          @unique
  name             String
  nameAr           String?
  type             String?
  model            String?
  manufacturer     String?
  manufactureYear  Int?
  plateNumber      String?
  serialNumber     String?
  status           EquipmentStatus @default(AVAILABLE)
  supplierId       String?
  purchasePrice    Float           @default(0)
  hourlyRate       Float           @default(0)
  dailyRate        Float           @default(0)
  monthlyRate      Float           @default(0)
  purchaseDate     DateTime?
  warrantyExpiry   DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  supplier       Supplier?             @relation(fields: [supplierId], references: [id])
  usages         EquipmentUsage[]
  maintenance    EquipmentMaintenance[]
  fuelLogs       EquipmentFuelLog[]
  rentals        EquipmentRental[]
  expenses       EquipmentExpense[]
  deliveryOrders EquipmentDeliveryOrder[]
  timesheets     Timesheet[]
  operatorLogs   EquipmentOperation[]
}

model EquipmentOperation {
  id          String   @id @default(cuid())
  equipmentId String
  operatorId  String?
  projectId   String?
  date        DateTime
  hours       Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  operator  Employee? @relation(fields: [operatorId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
}

model EquipmentUsage {
  id          String   @id @default(cuid())
  equipmentId String
  projectId   String
  date        DateTime
  hours       Float
  description String?
  cost        Float
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
}

model EquipmentMaintenance {
  id          String   @id @default(cuid())
  equipmentId String
  date        DateTime
  description String
  cost        Float
  supplierId  String?
  nextDate    DateTime?
  journalEntryId String?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])
}

model EquipmentFuelLog {
  id           String   @id @default(cuid())
  equipmentId  String
  projectId    String?
  date         DateTime
  liters       Float
  costPerLiter Float
  totalCost    Float
  journalEntryId String?
  createdAt    DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  project   Project?  @relation(fields: [projectId], references: [id])
}

model EquipmentCost {
  id          String   @id @default(cuid())
  projectId   String
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

// ============ EQUIPMENT RENTAL ============

model EquipmentRental {
  id              String     @id @default(cuid())
  contractId      String     @unique
  equipmentId     String
  clientId        String
  projectId       String?
  startDate       DateTime
  endDate         DateTime?
  rateType        String     @default("HOURLY")
  rate            Float
  deliveryFees    Float      @default(0)
  deliveryFeesTaxable Boolean @default(true)
  totalAmount     Float      @default(0)
  status          String     @default("ACTIVE")
  paymentTerms    String?
  salesOrderNo    String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  contract       Contract       @relation(fields: [contractId], references: [id])
  equipment      Equipment      @relation(fields: [equipmentId], references: [id])
  client         Client         @relation(fields: [clientId], references: [id])
  deliveryOrders EquipmentDeliveryOrder[]
  timesheets     Timesheet[]
}

model EquipmentDeliveryOrder {
  id            String   @id @default(cuid())
  orderNo       String   @unique
  rentalId      String?
  equipmentId   String
  clientId      String?
  projectId     String?
  site          String?
  deliveryDate  DateTime
  returnDate    DateTime?
  status        DeliveryOrderStatus @default(PENDING)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  equipment Equipment        @relation(fields: [equipmentId], references: [id])
  rental    EquipmentRental? @relation(fields: [rentalId], references: [id])
  client    Client?          @relation(fields: [clientId], references: [id])
}

model EquipmentExpense {
  id          String         @id @default(cuid())
  equipmentId String
  category    ExpenseCategory
  description String
  amount      Float
  date        DateTime
  reference   String?
  createdAt   DateTime       @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

// ============ TIMESHEETS ============

model Timesheet {
  id            String          @id @default(cuid())
  rentalId      String
  contractId    String
  projectId     String
  equipmentId   String
  month         Int
  year          Int
  operatingHours Float          @default(0)
  status        TimesheetStatus @default(DRAFT)
  approvedDate  DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  contract  Contract       @relation(fields: [contractId], references: [id])
  project   Project        @relation(fields: [projectId], references: [id])
  equipment Equipment      @relation(fields: [equipmentId], references: [id])
  rental    EquipmentRental @relation(fields: [rentalId], references: [id])
  invoice   SalesInvoice?
}

// ============ PETTY CASH & ADVANCES ============

model PettyCash {
  id            String   @id @default(cuid())
  branchId      String
  description   String
  amount        Float
  date          DateTime
  category      String?
  reference     String?
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
}

model EmployeeAdvance {
  id            String        @id @default(cuid())
  employeeId    String
  amount        Float
  date          DateTime
  settledAmount Float         @default(0)
  status        AdvanceStatus @default(PENDING)
  description   String?
  journalEntryId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ INVENTORY ============

model InventoryItem {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  nameAr        String?
  itemType      InventoryItemType @default(PRODUCT)
  unit          String
  purchasePrice Float             @default(0)
  sellingPrice  Float             @default(0)
  quantity      Float             @default(0)
  minQuantity   Float             @default(0)
  warehouseId   String
  category      String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
}

// ============ DOUBLE ENTRY ACCOUNTING ============

model Account {
  id       String   @id @default(cuid())
  code     String   @unique
  name     String
  nameAr   String?
  type     String
  parentId String?
  isActive Boolean  @default(true)

  parent      Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
}

model JournalEntry {
  id          String             @id @default(cuid())
  entryNo     String             @unique
  date        DateTime
  description String?
  status      JournalEntryStatus @default(POSTED)
  sourceType  String?
  sourceId    String?
  isReversal  Boolean            @default(false)
  reversedEntryId String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines JournalLine[]
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  costCenterId   String?
  debit          Float    @default(0)
  credit         Float    @default(0)
  description    String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])
}

// ============ VAT / TAX DECLARATION ============

model VATReturn {
  id              String         @id @default(cuid())
  year            Int
  quarter         Int
  period          String         @unique
  totalSales      Float          @default(0)
  outputVat       Float          @default(0)
  totalPurchases  Float          @default(0)
  inputVat        Float          @default(0)
  netVat          Float          @default(0)
  salesInvoiceIds String?
  purchaseInvoiceIds String?
  expenseIds      String?
  status          VATReturnStatus @default(DRAFT)
  filedDate       DateTime?
  paymentDate     DateTime?
  paymentReference String?
  journalEntryId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ============ CLIENT PAYMENTS ============

model ClientPayment {
  id            String   @id @default(cuid())
  clientId      String
  invoiceId     String?
  amount        Float
  date          DateTime
  receivedIn    String   @default("TREASURY")
  reference     String?
  notes         String?
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============ SUPPLIER PAYMENTS ============

model SupplierPayment {
  id            String   @id @default(cuid())
  supplierId    String
  invoiceId     String?
  amount        Float
  date          DateTime
  paidFrom      String   @default("TREASURY")
  bankAccount   String?
  paymentMethod String?
  reference     String?
  notes         String?
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
}

// ============ RESOURCE DISTRIBUTION ============

model ResourceAllocation {
  id          String   @id @default(cuid())
  projectId   String
  resourceType String  // EMPLOYEE, TEAM, EQUIPMENT
  resourceId  String   // ID of Employee/WorkTeam/Equipment
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}
